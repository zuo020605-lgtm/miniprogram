{
  "bsonType": "object",
  "required": ["openid"],
  "permission": {
    "read": true,
    "create": true,
    "update": true,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "ID"
    },
    "openid": {
      "bsonType": "string",
      "description": "用户唯一标识",
      "unique": true
    },
    "nickName": {
      "bsonType": "string",
      "description": "用户昵称"
    },
    "avatarUrl": {
      "bsonType": "string",
      "description": "用户头像"
    },
    "createdAt": {
      "bsonType": "timestamp",
      "description": "创建时间"
    },
    "updatedAt": {
      "bsonType": "timestamp",
      "description": "更新时间"
    },
    "lastLoginAt": {
      "bsonType": "timestamp",
      "description": "最后登录时间"
    },
    "loginCount": {
      "bsonType": "int",
      "description": "登录次数"
    }
  }
}
