<view class="custom-tabbar">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tabbar-item {{selected === index ? 'active' : ''}}"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    catchtap="switchTab"
  >
    <view class="tabbar-icon-shell">
      <view class="tabbar-symbol {{item.iconClass}}"></view>
      <view class="tabbar-badge" wx:if="{{index === 2 && unreadCount > 0}}">
        {{unreadCount > 99 ? '99+' : unreadCount}}
      </view>
    </view>
    <text
      class="tabbar-text"
      style="color: {{selected === index ? selectedColor : color}};"
    >
      {{item.text}}
    </text>
  </view>
</view>
