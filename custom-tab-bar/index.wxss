.custom-tabbar {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 24rpx;
  z-index: 999;
  height: 116rpx;
  padding: 10rpx 12rpx;
  padding-bottom: calc(10rpx + env(safe-area-inset-bottom));
  border-radius: 38rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.92), 0 24rpx 64rpx rgba(22, 38, 58, 0.16);
  -webkit-backdrop-filter: blur(32px) saturate(180%);
  backdrop-filter: blur(32px) saturate(180%);
  display: flex;
  align-items: center;
}

.tabbar-item {
  position: relative;
  flex: 1;
  height: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  overflow: visible;
  color: #8792a1;
  transition: transform 180ms cubic-bezier(0.2, 0.8, 0.2, 1), opacity 180ms ease;
}

.tabbar-item:active {
  transform: scale(0.9);
  opacity: 0.78;
}

.tabbar-icon-shell {
  position: relative;
  z-index: 1;
  width: 60rpx;
  height: 56rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: inherit;
  transition: transform 240ms cubic-bezier(0.2, 0.8, 0.2, 1), background 240ms ease, color 240ms ease, box-shadow 240ms ease;
}

.tabbar-symbol {
  width: 42rpx;
  height: 42rpx;
  color: currentColor;
}

.tabbar-badge {
  position: absolute;
  top: -8rpx;
  right: -10rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d9574f;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 30rpx;
  box-sizing: border-box;
  box-shadow: 0 6rpx 16rpx rgba(217, 87, 79, 0.24);
}

.tabbar-text {
  position: relative;
  z-index: 1;
  color: currentColor !important;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 0;
  transition: transform 240ms cubic-bezier(0.2, 0.8, 0.2, 1), color 240ms ease;
}

.tabbar-item.active {
  color: #0a84ff;
}

.tabbar-item.active .tabbar-icon-shell {
  transform: translateY(-10rpx);
  background: rgba(10, 132, 255, 0.13);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), 0 14rpx 30rpx rgba(10, 132, 255, 0.18);
}

.tabbar-item.active .tabbar-text {
  transform: translateY(-5rpx);
}

@media (prefers-color-scheme: dark) {
  .custom-tabbar {
    background: rgba(24, 34, 48, 0.78);
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.08), 0 24rpx 64rpx rgba(0, 0, 0, 0.34);
  }
}

/* iOS26 visual QA pass: glass layer on raised tab icons. */
.tabbar-icon-shell {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.92), rgba(239, 247, 255, 0.68));
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.95), 0 8rpx 22rpx rgba(22, 38, 58, 0.08);
  -webkit-backdrop-filter: blur(18px) saturate(170%);
  backdrop-filter: blur(18px) saturate(170%);
}

.tabbar-item.active .tabbar-icon-shell {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(219, 239, 255, 0.86));
  border-color: rgba(255, 255, 255, 0.96);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.96), 0 16rpx 34rpx rgba(10, 132, 255, 0.22);
}

@media (prefers-color-scheme: dark) {
  .tabbar-icon-shell {
    background: linear-gradient(145deg, rgba(36, 48, 66, 0.9), rgba(28, 38, 54, 0.72));
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.08), 0 8rpx 22rpx rgba(0, 0, 0, 0.26);
  }

  .tabbar-item.active .tabbar-icon-shell {
    background: linear-gradient(145deg, rgba(40, 58, 84, 0.96), rgba(20, 68, 120, 0.62));
    border-color: rgba(120, 185, 255, 0.26);
  }
}

/* Morandi tabbar pass. */
.custom-tabbar {
  background: rgba(250, 252, 251, 0.88) !important;
  border-color: rgba(105, 124, 134, 0.18) !important;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.82), 0 18rpx 46rpx rgba(58, 70, 76, 0.12) !important;
}

.tabbar-item {
  color: #737e83;
}

.tabbar-item.active {
  color: #4f6675 !important;
}

.tabbar-icon-shell {
  background: rgba(238, 243, 244, 0.92) !important;
  border-color: rgba(105, 124, 134, 0.16) !important;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.82), 0 8rpx 22rpx rgba(58, 70, 76, 0.08) !important;
}

.tabbar-item.active .tabbar-icon-shell {
  background: rgba(96, 120, 137, 0.14) !important;
  border-color: rgba(96, 120, 137, 0.22) !important;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.82), 0 14rpx 30rpx rgba(79, 102, 117, 0.16) !important;
}
