.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  height: 112rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  display: flex;
  align-items: center;
  box-shadow: 0 -8rpx 28rpx rgba(0, 0, 0, 0.08);
}

.custom-tabbar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: rgba(0, 0, 0, 0.06);
}

.tabbar-item {
  position: relative;
  z-index: 1;
  flex: 1;
  height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.tabbar-bulge {
  position: absolute;
  top: -22rpx;
  left: 50%;
  width: 112rpx;
  height: 82rpx;
  border-radius: 56rpx;
  background: #ffffff;
  opacity: 0;
  transform: translateX(-50%) scale(0.72);
  box-shadow: 0 -6rpx 20rpx rgba(0, 93, 164, 0.08);
  transition: all 0.24s cubic-bezier(0.2, 0.8, 0.2, 1);
  pointer-events: none;
}

.tabbar-icon-shell {
  position: relative;
  z-index: 1;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.24s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.tabbar-icon {
  width: 48rpx;
  height: 48rpx;
  transition: all 0.24s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.tabbar-text {
  position: relative;
  z-index: 1;
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 600;
  transition: all 0.24s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.tabbar-item.active .tabbar-bulge {
  opacity: 1;
  transform: translateX(-50%) scale(1);
}

.tabbar-item.active .tabbar-icon-shell {
  background: #eaf4ff;
  transform: translateY(-18rpx);
  box-shadow: 0 8rpx 18rpx rgba(0, 93, 164, 0.18);
}

.tabbar-item.active .tabbar-icon {
  transform: scale(1.08);
}

.tabbar-item.active .tabbar-text {
  transform: translateY(-10rpx);
  font-weight: 800;
}

.tabbar-item.active:active .tabbar-icon-shell {
  transform: translateY(-18rpx) scale(0.96);
}
