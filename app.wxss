}

/* ============================================
   Morandi consistency layer
   Restrained low-saturation palette and shared order blocks.
   ============================================ */

page,
:root {
  --mo-bg: #f3f5f6;
  --mo-bg-deep: #e8edf0;
  --mo-surface: rgba(253, 254, 253, 0.96);
  --mo-surface-soft: rgba(238, 243, 244, 0.96);
  --mo-glass: rgba(250, 252, 251, 0.84);
  --mo-border: rgba(105, 124, 134, 0.18);
  --mo-border-strong: rgba(105, 124, 134, 0.28);
  --mo-ink: #2f3538;
  --mo-text: #485156;
  --mo-muted: #737e83;
  --mo-primary: #607889;
  --mo-primary-deep: #4f6675;
  --mo-primary-soft: rgba(96, 120, 137, 0.14);
  --mo-sage: #819487;
  --mo-sage-soft: rgba(129, 148, 135, 0.14);
  --mo-clay: #a77f79;
  --mo-clay-soft: rgba(167, 127, 121, 0.14);
  --mo-warn: #9b875f;
  --mo-danger: #a06f6a;
  --mo-shadow: 0 16rpx 42rpx rgba(58, 70, 76, 0.1);
  --mo-shadow-soft: 0 8rpx 24rpx rgba(58, 70, 76, 0.07);

  --ios-bg: var(--mo-bg);
  --ios-bg-deep: var(--mo-bg-deep);
  --ios-surface: #fbfcfb;
  --ios-surface-soft: var(--mo-surface-soft);
  --ios-surface-raised: var(--mo-surface);
  --ios-glass: var(--mo-glass);
  --ios-glass-strong: rgba(253, 254, 253, 0.92);
  --ios-glass-border: var(--mo-border);
  --ios-text: var(--mo-ink);
  --ios-text-soft: var(--mo-text);
  --ios-text-muted: var(--mo-muted);
  --ios-tint: var(--mo-primary);
  --ios-tint-deep: var(--mo-primary-deep);
  --ios-tint-bright: #6f8796;
  --ios-tint-soft: var(--mo-primary-soft);
  --ios-mint: var(--mo-sage);
  --ios-coral: var(--mo-clay);
  --md-primary: var(--mo-primary);
  --md-primary-dim: var(--mo-primary-deep);
  --md-secondary: var(--mo-sage);
  --md-tertiary: var(--mo-clay);
  --md-error: var(--mo-danger);
  --md-success: var(--mo-sage);
  --md-warning: var(--mo-warn);
  --md-surface: var(--mo-bg);
  --md-background: var(--mo-bg);
  --md-on-surface: var(--mo-ink);
  --md-on-background: var(--mo-ink);
  --md-on-surface-variant: var(--mo-muted);
}

.page-container,
.home-page,
.publish-page,
.order-page,
.message-page,
.profile-page,
.my-orders-page,
.order-detail-page,
.payment-page,
.pay-success-page,
.success-page,
.login-page,
.auth-page,
.wallet-page,
.settings-page,
.help-page,
.security-page,
.review-page,
.report-page,
.campus-errand-page,
.express-page,
.exam-page,
.schedule-page,
.map-location-page,
.chat-page {
