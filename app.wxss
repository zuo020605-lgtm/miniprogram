  background:
    radial-gradient(circle at 12% -8%, rgba(96, 120, 137, 0.12), rgba(96, 120, 137, 0) 32%),
    radial-gradient(circle at 92% 8%, rgba(129, 148, 135, 0.1), rgba(129, 148, 135, 0) 28%),
    linear-gradient(180deg, var(--mo-bg) 0%, var(--mo-bg-deep) 100%) !important;
}

.section-card,
.order-card,
.recent-order-card,
.order-item,
.task-item,
.info-card,
.payment-content,
.success-content,
.account-section,
.stats-section,
.menu-section,
.identity-section,
