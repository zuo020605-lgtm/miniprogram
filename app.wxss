/* ============================================
   Campus Errand Mini Program - iOS26 redesign
   Liquid glass tokens with WeChat Mini Program fallbacks.
   ============================================ */

:root {
  --ios-bg: #f6f8fb;
  --ios-bg-deep: #eef3f9;
  --ios-surface: #ffffff;
  --ios-surface-soft: #f2f6fb;
  --ios-surface-raised: rgba(255, 255, 255, 0.92);
  --ios-glass: rgba(255, 255, 255, 0.72);
  --ios-glass-strong: rgba(255, 255, 255, 0.86);
  --ios-glass-border: rgba(255, 255, 255, 0.78);
  --ios-glass-shadow: 0 18rpx 54rpx rgba(28, 54, 84, 0.12);
  --ios-hairline: rgba(20, 35, 52, 0.09);
  --ios-text: #182331;
  --ios-text-soft: #5d6978;
  --ios-text-muted: #8792a1;
  --ios-tint: #0a84ff;
  --ios-tint-deep: #0068d8;
  --ios-mint: #26b99a;
  --ios-coral: #ff6b5f;
  --ios-gold: #f5a524;
  --ios-danger: #ff3b30;
  --ios-success: #34c759;
  --ios-warning: #ff9f0a;
  --ios-radius-xs: 8rpx;
  --ios-radius-sm: 12rpx;
  --ios-radius-md: 16rpx;
  --ios-radius-lg: 22rpx;
  --ios-radius-xl: 28rpx;
  --ios-radius-2xl: 36rpx;
  --ios-radius-full: 9999px;
  --ios-space-1: 8rpx;
  --ios-space-2: 16rpx;
  --ios-space-3: 24rpx;
  --ios-space-4: 32rpx;
  --ios-space-5: 40rpx;
  --ios-space-6: 48rpx;
  --ios-press: cubic-bezier(0.2, 0.8, 0.2, 1);
  --ios-ease: cubic-bezier(0.22, 1, 0.36, 1);

  /* Compatibility aliases for existing page WXSS. */
  --md-primary: var(--ios-tint);
  --md-primary-dim: var(--ios-tint-deep);
  --md-primary-container: #d8ebff;
  --md-on-primary: #ffffff;
  --md-on-primary-container: #073b71;
  --md-secondary: var(--ios-mint);
  --md-secondary-dim: #14977c;
  --md-secondary-container: #d9f7f0;
  --md-on-secondary: #ffffff;
  --md-on-secondary-container: #054b3e;
  --md-tertiary: #7c6df0;
  --md-tertiary-dim: #6456d8;
  --md-tertiary-container: #e7e4ff;
  --md-on-tertiary: #ffffff;
  --md-on-tertiary-container: #2d267a;
  --md-surface: var(--ios-bg);
  --md-surface-dim: #d8e2ee;
  --md-surface-bright: var(--ios-bg);
  --md-surface-container: #eaf0f7;
  --md-surface-container-low: #f1f5fa;
  --md-surface-container-high: #e3ebf5;
  --md-surface-container-highest: #d9e4f0;
  --md-surface-variant: #d9e4f0;
  --md-background: var(--ios-bg);
  --md-on-background: var(--ios-text);
  --md-on-surface: var(--ios-text);
  --md-on-surface-variant: var(--ios-text-soft);
  --md-outline: var(--ios-text-muted);
  --md-outline-variant: var(--ios-hairline);
  --md-error: var(--ios-danger);
  --md-error-dim: #d92d24;
  --md-error-container: #ffe1de;
  --md-on-error: #ffffff;
  --md-on-error-container: #7a110b;
  --md-success: var(--ios-success);
  --md-warning: var(--ios-warning);
  --radius-none: 0;
  --radius-xs: var(--ios-radius-xs);
  --radius-sm: var(--ios-radius-sm);
  --radius-md: var(--ios-radius-md);
  --radius-lg: var(--ios-radius-lg);
  --radius-xl: var(--ios-radius-xl);
  --radius-2xl: var(--ios-radius-2xl);
  --radius-full: var(--ios-radius-full);
  --shadow-none: none;
  --shadow-xs: 0 1rpx 2rpx rgba(19, 32, 48, 0.04);
  --shadow-sm: 0 8rpx 22rpx rgba(19, 32, 48, 0.06);
  --shadow-md: 0 14rpx 36rpx rgba(19, 32, 48, 0.09);
  --shadow-lg: var(--ios-glass-shadow);
  --shadow-xl: 0 28rpx 70rpx rgba(19, 32, 48, 0.16);
  --shadow-primary: 0 14rpx 34rpx rgba(10, 132, 255, 0.24);
  --text-xs: 20rpx;
  --text-sm: 22rpx;
  --text-base: 24rpx;
  --text-lg: 28rpx;
  --text-xl: 32rpx;
  --text-2xl: 36rpx;
  --text-3xl: 48rpx;
  --leading-none: 1;
  --leading-tight: 1.25;
  --leading-snug: 1.375;
  --leading-normal: 1.5;
  --leading-relaxed: 1.625;
  --space-0: 0;
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 40rpx;
  --space-6: 48rpx;
  --space-8: 64rpx;
  --space-10: 80rpx;
  --duration-fast: 120ms;
  --duration-normal: 220ms;
  --duration-slow: 360ms;
  --ease-default: var(--ios-ease);
  --ease-in: cubic-bezier(0.4, 0, 1, 1);
  --ease-out: cubic-bezier(0, 0, 0.2, 1);
  --ease-bounce: cubic-bezier(0.2, 0.9, 0.22, 1.18);
}

page {
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", Helvetica, Arial, sans-serif;
  color: var(--ios-text);
  background:
    radial-gradient(circle at 10% -5%, rgba(10, 132, 255, 0.13) 0, rgba(10, 132, 255, 0) 34%),
    radial-gradient(circle at 92% 4%, rgba(38, 185, 154, 0.12) 0, rgba(38, 185, 154, 0) 30%),
    linear-gradient(180deg, var(--ios-bg) 0%, var(--ios-bg-deep) 100%);
  line-height: 1.5;
  letter-spacing: 0;
  -webkit-font-smoothing: antialiased;
  box-sizing: border-box;
}

view,
scroll-view,
swiper,
button,
input,
textarea,
picker,
image,
text {
  box-sizing: border-box;
}

button {
  margin: 0;
}

button::after {
  border: none;
}

image {
  display: block;
}

.page-container,
.home-page,
.publish-page,
.order-page,
.profile-page,
.order-detail-page,
.payment-page,
.success-page,
.pay-success-page,
.message-page,
.chat-page,
.campus-errand-page,
.express-page,
.exam-page,
.schedule-page,
.map-location-page,
.review-page,
.report-page {
  min-height: 100vh !important;
  color: var(--ios-text) !important;
  background:
    radial-gradient(circle at 12% -10%, rgba(10, 132, 255, 0.13) 0, rgba(10, 132, 255, 0) 34%),
    radial-gradient(circle at 88% 8%, rgba(38, 185, 154, 0.11) 0, rgba(38, 185, 154, 0) 32%),
    linear-gradient(180deg, var(--ios-bg) 0%, var(--ios-bg-deep) 100%) !important;
}

.ios-glass,
.glass-header,
.header,
.chat-navbar,
.main-tab-nav,
.order-tabs,
.tab-nav,
.input-bar,
.confirm-button-container,
.location-info,
.search-bar,
.custom-tabbar {
  background: var(--ios-glass) !important;
  border: 1rpx solid var(--ios-glass-border) !important;
  box-shadow: var(--ios-glass-shadow) !important;
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  backdrop-filter: blur(24px) saturate(180%);
}

.header,
.chat-navbar,
.main-tab-nav,
.order-tabs,
.tab-nav,
.search-bar {
  border-left: none !important;
  border-right: none !important;
  border-top: none !important;
}

.card,
.order-card,
.recent-order-card,
.section-card,
.info-card,
.account-section,
.stats-section,
.menu-section,
.identity-section,
.login-section,
.message-item-card,
.result-item,
.course-modal,
.permission-card,
.payment-card,
.wallet-card,
.auth-card,
.settings-card,
.help-card,
.task-item,
.type-card,
.desc-card,
.image-card,
.contact-card,
.tip-card,
.rating-card,
.tags-card,
.content-card,
.order-info-card,
.search-history-panel,
.course-card,
.schedule-card,
.wallet-section,
.setting-section,
.help-section,
.payment-item,
.payment-methods,
.success-content,
.countdown-section,
.tips-section,
.security-section,
.danger-section,
.security-tips,
.empty-state {
  background: var(--ios-surface-raised) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.86) !important;
  border-radius: var(--ios-radius-2xl) !important;
  box-shadow: 0 14rpx 40rpx rgba(22, 38, 58, 0.09) !important;
  overflow: hidden;
}

.card-body,
.recent-route,
.task-type-note,
.form-textarea,
.input-wrapper,
.search-wrapper,
.picker-value,
.location-input-wrapper,
.menu-item,
.identity-item,
.type-icon-wrapper,
.empty-visual,
.permission-icon,
.service-badge,
.status-icon-wrapper,
.courier-avatar,
.avatar-placeholder,
.filter-item,
.tag-item,
.add-image,
.remove-btn,
.progress-track,
.search-input {
  background: rgba(255, 255, 255, 0.68) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.82) !important;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7), 0 8rpx 24rpx rgba(22, 38, 58, 0.06) !important;
}

.btn,
.btn-primary,
.permission-action,
.btn-accept,
.card-btn.primary,
.empty-action,
.publish-btn,
.submit-btn,
.login-btn,
.send-btn,
.confirm-button,
.location-btn-full,
.search-btn,
.task-btn,
.action-btn.primary {
  min-height: 64rpx;
  border-radius: var(--ios-radius-md) !important;
  background: linear-gradient(135deg, var(--ios-tint) 0%, var(--ios-tint-deep) 100%) !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow: 0 14rpx 30rpx rgba(10, 132, 255, 0.25) !important;
  transition: transform 160ms var(--ios-press), opacity 160ms var(--ios-press), box-shadow 220ms var(--ios-ease) !important;
}

.btn:active,
.btn-primary:active,
.permission-action:active,
.btn-accept:active,
.card-btn:active,
.empty-action:active,
.publish-btn:active,
.submit-btn:active,
.login-btn:active,
.send-btn:active,
.confirm-button:active,
.location-btn-full:active,
.search-btn:active,
.task-btn:active,
.action-btn:active,
.bento-item:active,
.type-item:active,
.menu-item:active,
.identity-item:active,
.recent-order-card:active,
.order-card:active,
.section-card:active {
  transform: scale(0.972) !important;
  opacity: 0.88;
}

.card-btn.secondary,
.card-btn.danger,
.btn-secondary,
.empty-action.secondary {
  background: rgba(255, 255, 255, 0.75) !important;
  color: var(--ios-tint) !important;
  border: 1rpx solid rgba(10, 132, 255, 0.2) !important;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8), 0 8rpx 22rpx rgba(22, 38, 58, 0.06) !important;
}

.filter-item,
.tag-item,
.main-tab-item,
.tab-item,
.type-item {
  transition: transform 160ms var(--ios-press), opacity 160ms var(--ios-press), background 220ms var(--ios-ease) !important;
}

.filter-item.active,
.tag-item.active,
.type-item.active {
  background: rgba(10, 132, 255, 0.13) !important;
  border-color: rgba(10, 132, 255, 0.34) !important;
  color: var(--ios-tint) !important;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.82), 0 12rpx 30rpx rgba(10, 132, 255, 0.13) !important;
}

.card-btn.danger {
  color: var(--ios-danger) !important;
  border-color: rgba(255, 59, 48, 0.22) !important;
}

.gradient-primary,
.gradient-secondary,
.gradient-tertiary,
.user-avatar,
.avatar-placeholder,
.status-card,
.message-item.message-self .message-bubble {
  background: linear-gradient(135deg, var(--ios-tint) 0%, #55b7ff 52%, var(--ios-mint) 100%) !important;
}

.bg-secondary-container,
.bg-surface-container-highest,
.bg-tertiary-container {
  background: rgba(255, 255, 255, 0.74) !important;
}

.text-primary,
.main-tab-item.active .main-tab-label,
.tab-item.active .tab-label,
.tab-item.active .tab-text,
.price-symbol,
.price-value,
.recent-price,
.auth-text,
.auth-arrow,
.weight-value,
.route-label {
  color: var(--ios-tint) !important;
}

.text-secondary,
.text-on-surface-variant,
.meta-text,
.recent-order-type,
.recent-order-id,
.order-id,
.location-text,
.empty-desc,
.user-id,
.reg-time,
.stats-label,
.row-label,
.type-desc,
.note-text,
.time-label,
.location-address,
.result-address,
.message-time {
  color: var(--ios-text-soft) !important;
}

.text-on-surface,
.card-title,
.recent-order-title,
.section-title,
.type-name,
.empty-title,
.user-name,
.stats-title,
.menu-title,
.identity-title,
.navbar-title,
.header-title,
.location-name,
.result-name {
  color: var(--ios-text) !important;
}

.main-tab-item.active::after,
.tab-item.active::after,
.weight-slider-progress,
.weight-slider-thumb,
.notification-badge {
  background: var(--ios-tint) !important;
  box-shadow: 0 8rpx 24rpx rgba(10, 132, 255, 0.22) !important;
}

.form-input,
.message-input,
.search-input,
.form-textarea,
input,
textarea {
  color: var(--ios-text) !important;
  caret-color: var(--ios-tint);
}

.form-input,
.search-input,
.message-input,
.form-textarea {
  background: rgba(255, 255, 255, 0.66) !important;
  border-radius: var(--ios-radius-lg) !important;
}

.tag,
.tab-count,
.badge-accepted,
.courier-badge,
.runner-badge,
.runner-badge-pending,
.lock-badge {
  border-radius: var(--ios-radius-full) !important;
}

.skeleton {
  background: linear-gradient(90deg, rgba(255,255,255,0.48) 25%, rgba(221,232,244,0.86) 50%, rgba(255,255,255,0.48) 75%) !important;
  background-size: 200% 100% !important;
  animation: ios-shimmer 1.4s infinite var(--ios-ease) !important;
}

@keyframes ios-shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

@keyframes ios-rise {
  0% { opacity: 0; transform: translateY(18rpx) scale(0.99); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

.hero-section,
.function-section,
.recent-order-list,
.order-list,
.publish-content,
.profile-content,
.content-scroll,
.message-list {
  animation: ios-rise 420ms var(--ios-ease) both;
}

.safe-area,
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.ios-icon,
.tabbar-symbol,
.css-service-icon {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ios-icon::before,
.tabbar-symbol::before,
.css-service-icon::before {
  content: '';
  display: block;
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid currentColor;
  border-radius: 12rpx;
}

.ios-icon::after,
.tabbar-symbol::after,
.css-service-icon::after {
  content: '';
  position: absolute;
  display: block;
}

.icon-home::before {
  width: 28rpx;
  height: 24rpx;
  border-radius: 6rpx 6rpx 10rpx 10rpx;
  transform: translateY(6rpx);
}

.icon-home::after {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  transform: translateY(-10rpx) rotate(45deg);
}

.icon-order::before {
  border-radius: 8rpx;
}

.icon-order::after {
  width: 18rpx;
  height: 4rpx;
  background: currentColor;
  box-shadow: 0 10rpx 0 currentColor, 0 20rpx 0 currentColor;
}

.icon-message::before {
  width: 34rpx;
  height: 26rpx;
  border-radius: 14rpx;
}

.icon-message::after {
  left: 13rpx;
  bottom: 7rpx;
  width: 10rpx;
  height: 10rpx;
  border-right: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: rotate(30deg);
}

.icon-profile::before {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  transform: translateY(-10rpx);
}

.icon-profile::after {
  bottom: 6rpx;
  width: 34rpx;
  height: 18rpx;
  border: 4rpx solid currentColor;
  border-radius: 18rpx 18rpx 8rpx 8rpx;
}

.icon-search::before {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  transform: translate(-4rpx, -4rpx);
}

.icon-search::after {
  width: 16rpx;
  height: 4rpx;
  background: currentColor;
  border-radius: 4rpx;
  transform: translate(12rpx, 13rpx) rotate(45deg);
}

.icon-bell::before {
  width: 26rpx;
  height: 28rpx;
  border-radius: 16rpx 16rpx 10rpx 10rpx;
}

.icon-bell::after {
  bottom: 6rpx;
  width: 12rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: currentColor;
}

.icon-school::before,
.icon-class::before {
  width: 34rpx;
  height: 28rpx;
  border-radius: 8rpx;
}

.icon-school::after,
.icon-class::after {
  width: 4rpx;
  height: 20rpx;
  background: currentColor;
  box-shadow: -10rpx 0 0 currentColor, 10rpx 0 0 currentColor;
}

.icon-run::before {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
}

.icon-run::after {
  width: 30rpx;
  height: 18rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: translate(6rpx, 10rpx) skewX(-18deg);
}

.icon-package::before {
  width: 32rpx;
  height: 30rpx;
  border-radius: 6rpx;
}

.icon-package::after {
  top: 20rpx;
  width: 34rpx;
  height: 4rpx;
  background: currentColor;
}

.icon-exam::before {
  width: 28rpx;
  height: 34rpx;
  border-radius: 6rpx;
}

.icon-exam::after {
  width: 16rpx;
  height: 4rpx;
  background: currentColor;
  box-shadow: 0 10rpx 0 currentColor;
}

.icon-plus::before {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
}

.icon-plus::after {
  width: 22rpx;
  height: 22rpx;
  background:
    linear-gradient(currentColor, currentColor) center / 22rpx 4rpx no-repeat,
    linear-gradient(currentColor, currentColor) center / 4rpx 22rpx no-repeat;
}

.icon-location::before {
  width: 26rpx;
  height: 32rpx;
  border-radius: 16rpx 16rpx 16rpx 4rpx;
  transform: rotate(-45deg);
}

.icon-location::after {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

.icon-time::before {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
}

.icon-time::after {
  width: 12rpx;
  height: 12rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: translate(3rpx, -3rpx);
}

.icon-copy::before {
  width: 24rpx;
  height: 28rpx;
  border-radius: 6rpx;
  transform: translate(5rpx, -4rpx);
}

.icon-copy::after {
  width: 24rpx;
  height: 28rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
  transform: translate(-5rpx, 4rpx);
}

.icon-back::before {
  width: 22rpx;
  height: 22rpx;
  border-right: 0;
  border-bottom: 0;
  border-radius: 4rpx 0 0 0;
  transform: rotate(-45deg);
}

.icon-back::after {
  width: 28rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: currentColor;
  transform: translate(5rpx, 0);
}

.icon-close::before {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
}

.icon-close::after {
  width: 20rpx;
  height: 20rpx;
  background:
    linear-gradient(currentColor, currentColor) center / 20rpx 4rpx no-repeat,
    linear-gradient(currentColor, currentColor) center / 4rpx 20rpx no-repeat;
  transform: rotate(45deg);
}

.icon-star::before {
  width: 30rpx;
  height: 30rpx;
  border-radius: 10rpx;
  transform: rotate(45deg) scale(0.86);
}

.icon-star::after {
  width: 14rpx;
  height: 14rpx;
  border-top: 4rpx solid currentColor;
  border-left: 4rpx solid currentColor;
  transform: translateY(-8rpx) rotate(45deg);
}

.icon-camera::before {
  width: 34rpx;
  height: 26rpx;
  border-radius: 8rpx;
  transform: translateY(4rpx);
}

.icon-camera::after {
  width: 12rpx;
  height: 12rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
  transform: translateY(5rpx);
}

.icon-shield::before {
  width: 30rpx;
  height: 34rpx;
  border-radius: 16rpx 16rpx 12rpx 12rpx;
}

.icon-shield::after {
  width: 12rpx;
  height: 20rpx;
  border-right: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: translateY(-4rpx) rotate(38deg);
}

.icon-more::before {
  width: 8rpx;
  height: 8rpx;
  border: none;
  border-radius: 50%;
  background: currentColor;
  box-shadow: -12rpx 0 0 currentColor, 12rpx 0 0 currentColor;
}

.icon-more::after {
  display: none;
}

.icon-send::before {
