.message-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 86% 4%, rgba(255, 195, 80, 0.16), rgba(255, 195, 80, 0) 30%),
    radial-gradient(circle at 8% 34%, rgba(46, 196, 182, 0.12), rgba(46, 196, 182, 0) 34%),
    linear-gradient(180deg, #f7f9fd 0%, #eef4f8 100%);
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.message-scroll {
  min-height: 100vh;
}

.message-toolbar {
  margin: 0 28rpx;
  padding: 28rpx 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.toolbar-title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: #2d2f33;
  line-height: 1.2;
}

.toolbar-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.refresh-btn {
  flex: 0 0 auto;
  height: 64rpx;
  min-width: 112rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  background: rgba(96, 120, 137, 0.14);
  color: #4f6675;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 64rpx;
  border: 1rpx solid rgba(96, 120, 137, 0.18);
}

.refresh-btn::after {
  border: none;
}

.message-list {
  padding: 28rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.message-page .message-item {
  display: block !important;
  width: 100%;
  margin-bottom: 22rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94) !important;
  border: 1rpx solid rgba(0, 88, 187, 0.12) !important;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.96), 0 18rpx 44rpx rgba(22, 38, 58, 0.1) !important;
  box-sizing: border-box;
  transition: transform 160ms cubic-bezier(0.2, 0.8, 0.2, 1), opacity 160ms ease;
}

.message-page .message-item:active {
  transform: scale(0.982);
  opacity: 0.86;
}

.message-page .card-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
  min-width: 0;
}

.message-page .service-badge {
  flex: 0 0 72rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, rgba(255, 237, 234, 0.96), rgba(255, 216, 208, 0.84)) !important;
  border: 1rpx solid rgba(255, 111, 97, 0.18);
  color: #b23a2f;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.96), 0 10rpx 24rpx rgba(255, 111, 97, 0.14);
}

.message-page .avatar-text {
  font-size: 28rpx;
  font-weight: 900;
  color: #b23a2f !important;
}

.message-page .card-title-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.message-page .card-title {
  max-width: 100%;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 850;
  color: #2d2f33 !important;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-page .card-meta {
  display: flex;
  align-items: center;
}

.message-page .meta-text {
  max-width: 100%;
  font-size: 22rpx;
  line-height: 1.35;
  color: #6b7280 !important;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-page .tab-count {
  flex: 0 0 auto;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff6f61 !important;
  color: #ffffff !important;
  font-size: 20rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 20rpx rgba(255, 111, 97, 0.24);
  box-sizing: border-box;
}

.message-page .card-body {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(241, 247, 252, 0.96) !important;
  border: 1rpx solid rgba(0, 88, 187, 0.1) !important;
}

.message-page .location-text {
  display: block;
  width: 100%;
  font-size: 25rpx;
  line-height: 1.5;
  color: #59636f !important;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 24rpx 32rpx 40rpx;
}

.load-text {
  font-size: 24rpx;
  color: #6b7280;
}

.empty-container {
  min-height: 560rpx;
  padding: 96rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.empty-visual {
  width: 128rpx;
  height: 128rpx;
  margin-bottom: 28rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, rgba(229, 255, 248, 0.96), rgba(199, 244, 236, 0.78));
  border: 1rpx solid rgba(38, 185, 154, 0.18);
  color: #147d6f;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.96), 0 16rpx 36rpx rgba(38, 185, 154, 0.14);
}

.empty-visual .ios-icon {
  width: 66rpx;
  height: 66rpx;
  color: #147d6f !important;
}

.empty-title {
  margin-bottom: 12rpx;
  font-size: 32rpx;
  font-weight: 850;
  color: #2d2f33;
}

.empty-desc {
  font-size: 25rpx;
  line-height: 1.5;
  color: #6b7280;
}

.safe-area {
  height: calc(150rpx + env(safe-area-inset-bottom));
}

@media (prefers-color-scheme: dark) {
  .message-page {
    background:
      radial-gradient(circle at 86% 4%, rgba(255, 195, 80, 0.1), rgba(255, 195, 80, 0) 30%),
      linear-gradient(180deg, #0e141c 0%, #151f2b 100%);
  }

  .message-page .message-item,
  .message-page .card-body {
    background: rgba(26, 36, 50, 0.9) !important;
    border-color: rgba(255, 255, 255, 0.12) !important;
  }

  .message-page .card-title,
  .empty-title {
    color: #f6f8fb !important;
  }

  .message-page .meta-text,
  .message-page .location-text,
  .empty-desc,
  .load-text {
    color: #bac6d4 !important;
  }
}

/* Morandi message pass. */
.message-page {
  background:
    radial-gradient(circle at 86% 4%, rgba(129, 148, 135, 0.1), rgba(129, 148, 135, 0) 30%),
    linear-gradient(180deg, #f3f5f6 0%, #e8edf0 100%) !important;
}

.message-page .message-item {
  background: rgba(253, 254, 253, 0.96) !important;
  border-color: rgba(105, 124, 134, 0.18) !important;
  box-shadow: 0 16rpx 42rpx rgba(58, 70, 76, 0.1) !important;
}

.message-page .service-badge,
.message-page .empty-visual {
  background: rgba(96, 120, 137, 0.12) !important;
  border-color: rgba(96, 120, 137, 0.16) !important;
  color: #607889 !important;
}

.message-page .avatar-text,
.message-page .empty-visual .ios-icon {
  color: #607889 !important;
}

.message-page .card-body {
  background: rgba(238, 243, 244, 0.96) !important;
  border-color: rgba(105, 124, 134, 0.12) !important;
}

.message-page .tab-count {
  background: rgba(96, 120, 137, 0.14) !important;
  color: #4f6675 !important;
  box-shadow: none !important;
}
