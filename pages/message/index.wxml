<view class="message-page">
    <view class="message-list">
      <view 
        class="message-item" 
        wx:for="{{conversations}}" wx:for-item="conversation" wx:for-index="index" wx:key="{{conversation._id || conversation.id || index}}"
        bindtap="navigateToChat"
        data-conversation="{{conversation}}"
      >
        <view class="message-avatar">
          <text class="avatar-text">{{conversation.name.charAt(0)}}</text>
        </view>
        <view class="message-info">
          <view class="message-header">
            <text class="message-name">{{conversation.name}}</text>
            <text class="message-time">{{conversation.lastMessageTime}}</text>
          </view>
          <text class="message-preview">{{conversation.lastMessage}}</text>
        </view>
        <view class="message-badge" wx:if="{{conversation.unreadCount > 0}}">{{conversation.unreadCount}}</view>
      </view>
    </view>
  </view>