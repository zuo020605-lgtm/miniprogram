<view class="page">
    <view class="section">
      <view class="section-title">个人设置</view>
      <view class="item" bindtap="editProfile">
        <text class="label">个人信息</text>
        <text class="arrow">＞</text>
      </view>
      <view class="item" bindtap="changeAvatar">
        <text class="label">更换头像</text>
        <text class="arrow">＞</text>
      </view>
    </view>
    
    <view class="section">
      <view class="section-title">通知设置</view>
      <view class="item">
        <text class="label">消息通知</text>
        <switch :checked="messageNotification" bindchange="toggleMessage" />
      </view>
      <view class="item">
        <text class="label">系统通知</text>
        <switch :checked="systemNotification" bindchange="toggleSystem" />
      </view>
    </view>
    
    <view class="section">
      <view class="section-title">隐私设置</view>
      <view class="item">
        <text class="label">公开个人信息</text>
        <switch :checked="publicProfile" bindchange="togglePublic" />
      </view>
      <view class="item" bindtap="clearCache">
        <text class="label">清除缓存</text>
        <text class="value">{{cacheSize}}</text>
      </view>
    </view>
    
    <view class="section">
      <view class="section-title">关于</view>
      <view class="item" bindtap="aboutUs">
        <text class="label">关于我们</text>
        <text class="arrow">＞</text>
      </view>
      <view class="item" bindtap="checkUpdate">
        <text class="label">检查更新</text>
        <text class="value">v1.0.0</text>
      </view>
    </view>
  </view>