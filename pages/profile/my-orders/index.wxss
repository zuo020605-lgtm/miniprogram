.my-orders-page {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 80px;
}

.my-orders-content {
  display: flex;
  flex-direction: column;
}

/* 标签页 */
.tabs {
  display: flex;
  background: #fff;
  padding: 0 32rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  position: relative;
  transition: all 0.3s ease;
}

.tab:active {
  background-color: rgba(0, 0, 0, 0.02);
}

.tab.active {
  color: #3b82f6;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 56rpx;
  height: 8rpx;
  background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 100%);
  border-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.4);
  transition: all 0.3s ease;
}

.tab-text {
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  letter-spacing: 1rpx;
}

.tab.active .tab-text {
  font-weight: 700;
}

/* 接单列表 */
.orders-list {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.order-item {
  background-color: #ffffff;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12px;
}

.order-title {
  font-size: 14px;
  font-weight: 600;
  color: #2c2f32;
  flex: 1;
  margin-right: 12px;
}

.order-status {
  font-size: 10px;
  font-weight: 600;
  padding: 4px 8px;
  border-radius: 8px;
  text-transform: uppercase;
}

.order-status.pending {
  background-color: rgba(255, 193, 7, 0.1);
  color: #ff9800;
}

.order-status.processing {
  background-color: rgba(30, 136, 229, 0.1);
  color: #1E88E5;
}

.order-status.completed {
  background-color: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

.order-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.order-price {
  font-size: 16px;
  font-weight: 800;
  color: #1E88E5;
}

.order-time {
  font-size: 12px;
  color: #9a9da0;
}

.order-actions {
  display: flex;
  gap: 12px;
}

.action-btn {
  flex: 1;
  padding: 8px;
  border: 1px solid #1E88E5;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 600;
  color: #1E88E5;
  background-color: #ffffff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  text-align: center;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 14px;
  color: #9a9da0;
  margin-bottom: 24px;
}

.empty-btn {
  padding: 12px 32px;
  background-color: #1E88E5;
  color: #ffffff;
  border: none;
  border-radius: 24px;
  font-size: 14px;
  font-weight: 600;
}

/* Morandi consistency pass. */
.my-orders-page {
  background:
    radial-gradient(circle at 88% -4%, rgba(129, 148, 135, 0.12), rgba(129, 148, 135, 0) 30%),
    linear-gradient(180deg, #f3f5f6 0%, #e8edf0 100%) !important;
}

.tabs {
  gap: 10rpx;
  padding: 18rpx 20rpx !important;
  background: rgba(250, 252, 251, 0.92) !important;
  border-bottom: 1rpx solid rgba(105, 124, 134, 0.18) !important;
  box-shadow: 0 8rpx 24rpx rgba(58, 70, 76, 0.07) !important;
}

.tab {
  height: 68rpx;
  padding: 0 10rpx !important;
  border-radius: 20rpx;
  color: #737e83 !important;
}

.tab.active {
  background: rgba(96, 120, 137, 0.14) !important;
  color: #4f6675 !important;
}

.tab.active::after {
  display: none !important;
}

.orders-list {
  padding: 24rpx !important;
  gap: 22rpx !important;
}

.order-item {
  padding: 28rpx !important;
  border-radius: 28rpx !important;
  background: rgba(253, 254, 253, 0.96) !important;
  border: 1rpx solid rgba(105, 124, 134, 0.18) !important;
  box-shadow: 0 16rpx 42rpx rgba(58, 70, 76, 0.1) !important;
}

.order-title {
  color: #2f3538 !important;
  font-size: 30rpx !important;
}

.order-status,
.order-status.pending,
.order-status.processing,
.order-status.completed {
  background: rgba(96, 120, 137, 0.14) !important;
  color: #4f6675 !important;
}

.order-info {
  background: rgba(238, 243, 244, 0.96) !important;
  border: 1rpx solid rgba(105, 124, 134, 0.12) !important;
  border-radius: 20rpx !important;
  padding: 20rpx !important;
}

.order-price {
  color: #4f6675 !important;
}

.order-time {
  color: #737e83 !important;
}

.action-btn {
  border-color: rgba(105, 124, 134, 0.24) !important;
  color: #4f6675 !important;
  background: rgba(238, 243, 244, 0.96) !important;
  border-radius: 20rpx !important;
}

.empty-btn {
  background: linear-gradient(135deg, #607889 0%, #4f6675 100%) !important;
  color: #ffffff !important;
}
