<view class="page-container">
    <!-- 标签切换 -->
    <view class="tab-nav">
      <view
        class="tab-item {{currentTab === 'unaccepted' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="unaccepted"
      >
        <text class="tab-label">待接取</text>
        <view class="tab-count" wx:if="{{tabCounts.unaccepted > 0}}">{{ tabCounts.unaccepted }}</view>
      </view>
      <view
        class="tab-item {{currentTab === 'processing' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="processing"
      >
        <text class="tab-label">进行中</text>
        <view class="tab-count processing" wx:if="{{tabCounts.processing > 0}}">{{ tabCounts.processing }}</view>
      </view>
      <view
        class="tab-item {{currentTab === 'completed' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="completed"
      >
        <text class="tab-label">已完成</text>
        <view class="tab-count done" wx:if="{{tabCounts.completed > 0}}">{{ tabCounts.completed }}</view>
      </view>
      <view
        class="tab-item {{currentTab === 'cancelled' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="cancelled"
      >
        <text class="tab-label">已取消</text>
        <view class="tab-count done" wx:if="{{tabCounts.cancelled > 0}}">{{ tabCounts.cancelled }}</view>
      </view>
    </view>

    <!-- 加载骨架屏 -->
    <view wx:if="{{isLoading}}" class="skeleton-container">
      <view class="skeleton skeleton-card" wx:for="{{3}}" wx:key="index"></view>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{displayOrders.length === 0}}" class="empty-container">
      <view class="empty-visual">
        <view class="ios-icon icon-order icon-order-empty"></view>
      </view>
      <text class="empty-title">{{ emptyTitle }}</text>
      <text class="empty-desc">{{ emptyDesc }}</text>
      <button class="empty-action" bindtap="goPublish">
        <view class="ios-icon icon-plus icon-add"></view>
        <text>发布任务</text>
      </button>
    </view>

    <!-- 订单列表 -->
    <scroll-view
      wx:else
      scroll-y
      class="order-scroll"
      bindscrolltolower="loadMore"
    >
      <view class="order-list">
        <view
          class="swipe-cell {{item.swiped ? 'is-open' : ''}}"
          wx:for="{{displayOrders}}"
          wx:key="id"
        >
          <view
            class="swipe-delete"
            catchtap="handleSwipeDelete"
            data-id="{{item.id}}"
          >
            删除
          </view>

          <view
            class="order-card swipe-content"
            bindtap="openDetail"
            catchtouchstart="onOrderTouchStart"
            catchtouchmove="onOrderTouchMove"
            data-index="{{index}}"
            data-id="{{item.id}}"
          >
            <!-- 卡片头部 -->
            <view class="card-header">
              <view class="service-badge" >
                <view class="ios-icon icon-school icon-nav"></view>
              </view>
              <view class="card-title-wrap">
                <text class="card-title">{{ item.title || '未命名任务' }}</text>
                <view class="card-meta">
                  <view class="ios-icon icon-time icon-inline"></view>
                  <text class="meta-text">{{ item.createdAtText }}</text>
                </view>
              </view>
              <view class="card-price">
                <text class="price-symbol">¥</text>
                <text class="price-value">{{ item.price }}</text>
              </view>
            </view>

            <!-- 卡片内容 -->
            <view class="card-body">
              <view class="location-row">
                <view class="ios-icon icon-location icon-inline"></view>
                <text class="location-text">{{ item.locationInfo || '暂无位置信息' }}</text>
              </view>
            </view>

            <!-- 卡片操作 -->
            <view class="card-footer">
              <button class="card-btn secondary" catchtap="openDetail" data-id="{{item._id}}">
                <view class="ios-icon icon-order icon-inline"></view>
                <text>查看详情</text>
              </button>
              <button
                class="card-btn danger"
                wx:if="{{currentTab === 'unaccepted'}}"
                catchtap="handleCancel"
                data-id="{{item._id}}"
              >
                <view class="ios-icon icon-close icon-inline"></view>
                <text>取消</text>
              </button>
              <button
                class="card-btn primary"
                wx:if="{{currentTab === 'completed'}}"
                catchtap="handleRepost"
                data-id="{{item._id}}"
              >
                <view class="ios-icon icon-refresh icon-inline"></view>
                <text>再来一单</text>
              </button>
            </view>
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{hasMore}}">
        <text class="load-text">{{ loadingMore ? '加载中...' : '上拉加载更多' }}</text>
      </view>

      <!-- 底部安全区 -->
      <view class="safe-area"></view>
    </scroll-view>
  </view>
