<view class="auth-page">
    <view class="auth-content">
      <view class="auth-header">
        <text class="auth-title">{{authType === 'runner' ? '接单员认证' : '实名认证'}}</text>
        <text class="auth-subtitle">{{authType === 'runner' ? '提交申请后，审核通过即可接取任务' : '完成实名认证后可享受更多服务'}}</text>
      </view>
      
      <view class="auth-form" wx:if="{{authType === 'runner'}}">
        <view class="form-item">
          <text class="form-label">真实姓名</text>
          <input type="text" placeholder="请输入真实姓名" value="{{realName}}" bindinput="onRealNameChange" class="form-input" />
        </view>
        <view class="form-item">
          <text class="form-label">学号/工号</text>
          <input type="text" placeholder="请输入学号或工号" value="{{studentNo}}" bindinput="onStudentNoChange" class="form-input" />
        </view>
        <view class="form-item">
          <text class="form-label">联系方式</text>
          <input type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneChange" class="form-input" />
        </view>
        <checkbox-group bindchange="onRunnerAgreementChange">
          <label class="agreement-row">
            <checkbox value="agree" checked="{{runnerAgreement}}" />
            <text class="agreement-text">我已阅读并同意接单员服务协议</text>
          </label>
        </checkbox-group>
        <button class="auth-btn" bindtap="submitAuth">提交申请</button>
      </view>

      <view class="auth-form" wx:else>
        <view class="form-item">
          <text class="form-label">真实姓名</text>
          <input type="text" placeholder="请输入真实姓名" value="{{realName}}" bindinput="onRealNameChange" class="form-input" />
        </view>
        <view class="form-item">
          <text class="form-label">身份证号</text>
          <input type="text" placeholder="请输入身份证号" value="{{idCard}}" bindinput="onIdCardChange" class="form-input" />
        </view>
        <view class="form-item">
          <text class="form-label">手机号</text>
          <input type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneChange" class="form-input" />
        </view>
        <view class="form-item">
          <text class="form-label">验证码</text>
          <view class="verification-code">
            <input type="number" placeholder="请输入验证码" value="{{verificationCode}}" bindinput="onVerificationCodeChange" class="form-input code-input" />
            <button class="get-code-btn" bindtap="getVerificationCode" disabled="{{countdown > 0}}">
              <text wx:if="{{countdown > 0}}">{{countdownText}}</text>
              <text wx:else>获取验证码</text>
            </button>
          </view>
        </view>
        <button class="auth-btn" bindtap="submitAuth">提交认证</button>
      </view>
      
      <view class="auth-tips">
        <block wx:if="{{authType === 'runner'}}">
          <text class="tips-text">* 接单员认证审核时间通常为 1-3 个工作日</text>
          <text class="tips-text">* 认证通过后可在订单页查看并接取最近发布任务</text>
        </block>
        <block wx:else>
          <text class="tips-text">* 我们会严格保护您的个人信息安全</text>
          <text class="tips-text">* 实名认证后不可修改，请确保信息准确</text>
        </block>
      </view>
    </view>
  </view>
