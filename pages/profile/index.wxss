.profile-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf4 100%);
  padding-top: 20px;
  padding-bottom: 80px;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.profile-content {
  padding: 20px 24px;
}

/* 账户管理 */
.account-section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 24px;
  margin-bottom: 20px;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.account-section:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
}

.account-header {
  display: flex;
  align-items: center;
}

.avatar-container {
  position: relative;
  width: 80px;
  height: 80px;
  margin-right: 20px;
  flex-shrink: 0;
}

.avatar-placeholder {
  width: 80px;
  height: 80px;
  border-radius: 40px;
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  box-shadow: 0 4px 16px rgba(99, 102, 241, 0.3);
}

.avatar-icon {
  font-size: 32px;
  color: #ffffff;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.runner-badge,
.runner-badge-pending {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: #fff;
  font-weight: 700;
  border: 2rpx solid #fff;
  box-sizing: border-box;
}

.runner-badge {
  background: linear-gradient(135deg, #f59e0b, #d97706);
}

.runner-badge-pending {
  background: #60a5fa;
}

.account-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.user-name {
  font-size: 18px;
  font-weight: 600;
  color: #2c2f32;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.user-id {
  font-size: 14px;
  color: #9a9da0;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.reg-time {
  font-size: 14px;
  color: #9a9da0;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.auth-status {
  display: flex;
  align-items: center;
  margin-top: 4px;
}

.auth-text {
  font-size: 14px;
  color: #6366F1;
  margin-right: 4px;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.auth-arrow {
  font-size: 14px;
  color: #6366F1;
}

/* 数据统计 */
.stats-section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.stats-section:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
}

.stats-header {
  margin-bottom: 16px;
}

.stats-title {
  font-size: 16px;
  font-weight: 600;
  color: #2c2f32;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.stats-content {
  display: flex;
  justify-content: space-between;
}

.stats-item {
  flex: 1;
  text-align: center;
  padding: 10px 6px;
}

.stats-value {
  font-size: 20px;
  font-weight: 800;
  color: #6366F1;
  display: block;
  margin-bottom: 4px;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.stats-label {
  font-size: 12px;
  color: #9a9da0;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.review-list {
  margin-top: 18px;
  padding-top: 16px;
  border-top: 1px solid rgba(105, 124, 134, 0.16);
}

.review-list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.review-list-title {
  font-size: 14px;
  font-weight: 700;
  color: #2c2f32;
}

.review-list-count {
  font-size: 12px;
  color: #8a949a;
}

.review-item {
  padding: 12px;
  margin-bottom: 10px;
  border-radius: 18rpx;
  background: rgba(238, 243, 244, 0.78);
  border: 1rpx solid rgba(105, 124, 134, 0.14);
}

.review-item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 6px;
}

.review-order {
  flex: 1;
  min-width: 0;
  font-size: 13px;
  font-weight: 700;
  color: #485156;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.review-rating {
  flex-shrink: 0;
  font-size: 12px;
  color: #4f6675;
  font-weight: 700;
}

.review-content {
  display: block;
  font-size: 12px;
  line-height: 1.45;
  color: #5f696e;
  margin-bottom: 6px;
}

.review-tags {
  display: block;
  font-size: 11px;
  color: #8a949a;
}

.review-empty {
  padding: 12px;
  border-radius: 18rpx;
  background: rgba(238, 243, 244, 0.58);
  color: #8a949a;
  font-size: 12px;
  text-align: center;
}

/* 功能入口 */
.menu-section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.menu-section:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
}

.menu-header {
  margin-bottom: 16px;
}

.menu-title {
  font-size: 16px;
  font-weight: 600;
  color: #2c2f32;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.menu-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 16px;
  border-radius: 32rpx;
  background-color: #f8f9fa;
  transition: all 0.3s ease;
}

.menu-item:active {
  background-color: #e5e8ec;
  transform: scale(0.98);
}

.menu-item-disabled {
  opacity: 0.62;
}

.menu-item-disabled:active {
  background-color: #f8f9fa;
  transform: none;
}

.menu-item-runner {
  background-color: rgba(34, 197, 94, 0.12);
}

.menu-item-runner .menu-text {
  color: #15803d;
  font-weight: 700;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  object-fit: contain;
}

.lock-badge {
  position: absolute;
  top: 10rpx;
  right: 14rpx;
  width: 30rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 15rpx;
  background: rgba(44, 47, 50, 0.72);
  color: #ffffff;
  font-size: 16rpx;
  line-height: 30rpx;
}

.menu-text {
  font-size: 12px;
  color: #2c2f32;
  text-align: center;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

/* 身份切换 */
.identity-section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.identity-section:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
}

.identity-header {
  margin-bottom: 16px;
}

.identity-title {
  font-size: 16px;
  font-weight: 600;
  color: #2c2f32;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.identity-content {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.identity-item {
  display: flex;
  align-items: center;
  padding: 16px;
  border-radius: 32rpx;
  background-color: #f8f9fa;
  transition: all 0.3s ease;
}

.identity-item:active {
  background-color: #e5e8ec;
  transform: scale(0.98);
}

.identity-icon {
  font-size: 20px;
  margin-right: 12px;
  color: #6366F1;
}

.identity-text {
  flex: 1;
  font-size: 14px;
  color: #2c2f32;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.identity-arrow {
  font-size: 16px;
  color: #9a9da0;
}

/* 未登录状态 */
.login-section {
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 40px 24px;
  margin-bottom: 20px;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
  display: flex;
  justify-content: center;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

.login-info {
  text-align: center;
}

.login-text {
  font-size: 18px;
  font-weight: 600;
  color: #2c2f32;
  display: block;
  margin-bottom: 4px;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.login-subtext {
  font-size: 14px;
  color: #9a9da0;
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.login-btn {
  padding: 12px 32px;
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  font-size: 14px;
  font-weight: 600;
  transition: all 0.3s ease;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  box-shadow: 0 4px 16px rgba(99, 102, 241, 0.3);
}

.login-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}
