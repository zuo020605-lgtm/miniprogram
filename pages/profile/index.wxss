.profile-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf4 100%);
  padding-top: 20px;
  padding-bottom: 80px;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.profile-content {
  padding: 20px 24px;
}

/* 账户管理 */
.account-section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 24px;
  margin-bottom: 20px;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.account-section:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
}

.account-header {
  display: flex;
  align-items: center;
}

.avatar-placeholder {
  width: 80px;
  height: 80px;
  border-radius: 40px;
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20px;
  overflow: hidden;
  box-shadow: 0 4px 16px rgba(99, 102, 241, 0.3);
}

.avatar-icon {
  font-size: 32px;
  color: #ffffff;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.account-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.user-name {
  font-size: 18px;
  font-weight: 600;
  color: #2c2f32;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.user-id {
  font-size: 14px;
  color: #9a9da0;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.reg-time {
  font-size: 14px;
  color: #9a9da0;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.auth-status {
  display: flex;
  align-items: center;
  margin-top: 4px;
}

.auth-text {
  font-size: 14px;
  color: #6366F1;
  margin-right: 4px;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.auth-arrow {
  font-size: 14px;
  color: #6366F1;
}

/* 数据统计 */
.stats-section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.stats-section:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
}

.stats-header {
  margin-bottom: 16px;
}

.stats-title {
  font-size: 16px;
  font-weight: 600;
  color: #2c2f32;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.stats-content {
  display: flex;
  justify-content: space-between;
}

.stats-item {
  flex: 1;
  text-align: center;
  padding: 12px;
}

.stats-value {
  font-size: 20px;
  font-weight: 800;
  color: #6366F1;
  display: block;
  margin-bottom: 4px;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.stats-label {
  font-size: 12px;
  color: #9a9da0;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

/* 功能入口 */
.menu-section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.menu-section:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
}

.menu-header {
  margin-bottom: 16px;
}

.menu-title {
  font-size: 16px;
  font-weight: 600;
  color: #2c2f32;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 16px;
  border-radius: 32rpx;
  background-color: #f8f9fa;
  transition: all 0.3s ease;
}

.menu-item:active {
  background-color: #e5e8ec;
  transform: scale(0.98);
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  object-fit: contain;
}

.menu-text {
  font-size: 12px;
  color: #2c2f32;
  text-align: center;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

/* 身份切换 */
.identity-section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.identity-section:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
}

.identity-header {
  margin-bottom: 16px;
}

.identity-title {
  font-size: 16px;
  font-weight: 600;
  color: #2c2f32;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.identity-content {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.identity-item {
  display: flex;
  align-items: center;
  padding: 16px;
  border-radius: 32rpx;
  background-color: #f8f9fa;
  transition: all 0.3s ease;
}

.identity-item:active {
  background-color: #e5e8ec;
  transform: scale(0.98);
}

.identity-icon {
  font-size: 20px;
  margin-right: 12px;
  color: #6366F1;
}

.identity-text {
  flex: 1;
  font-size: 14px;
  color: #2c2f32;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.identity-arrow {
  font-size: 16px;
  color: #9a9da0;
}

/* 未登录状态 */
.login-section {
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 40px 24px;
  margin-bottom: 20px;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
  display: flex;
  justify-content: center;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

.login-info {
  text-align: center;
}

.login-text {
  font-size: 18px;
  font-weight: 600;
  color: #2c2f32;
  display: block;
  margin-bottom: 4px;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.login-subtext {
  font-size: 14px;
  color: #9a9da0;
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.login-btn {
  padding: 12px 32px;
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  font-size: 14px;
  font-weight: 600;
  transition: all 0.3s ease;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  box-shadow: 0 4px 16px rgba(99, 102, 241, 0.3);
}

.login-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}