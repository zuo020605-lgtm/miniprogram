.help-page {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 24px;
}

.help-content {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.help-header {
  text-align: center;
  margin-bottom: 16px;
}

.help-title {
  font-size: 20px;
  font-weight: 600;
  color: #2c2f32;
  display: block;
  margin-bottom: 8px;
}

.help-subtitle {
  font-size: 14px;
  color: #9a9da0;
  display: block;
}

.help-section {
  background-color: #ffffff;
  border-radius: 16px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.section-title {
  padding: 16px 20px;
  font-size: 14px;
  font-weight: 600;
  color: #9a9da0;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  border-bottom: 1px solid #e5e8ec;
}

.help-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid #e5e8ec;
}

.help-item:last-child {
  border-bottom: none;
}

.help-question {
  font-size: 14px;
  color: #2c2f32;
  flex: 1;
}

.help-arrow {
  font-size: 16px;
  color: #9a9da0;
}

.contact-section {
  background-color: #ffffff;
  border-radius: 16px;
  padding: 24px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
  text-align: center;
}

.contact-title {
  font-size: 16px;
  font-weight: 600;
  color: #2c2f32;
  display: block;
  margin-bottom: 16px;
}

.contact-info {
  font-size: 14px;
  color: #9a9da0;
  display: block;
  margin-bottom: 8px;
}

.contact-btn {
  margin-top: 20px;
  padding: 12px 32px;
  background-color: #1E88E5;
  color: #ffffff;
  border: none;
  border-radius: 24px;
  font-size: 14px;
  font-weight: 600;
}