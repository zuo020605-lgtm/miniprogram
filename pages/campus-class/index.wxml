<view class="schedule-page">
  <view class="schedule-nav">
    <view class="nav-action-btn" bindtap="showtip">
      <text class="nav-action-icon">☰</text>
      <text class="nav-action-text">课表操作</text>
    </view>
    <view class="nav-week" bindtap="showpoint">
      <text>第 {{ currentWeek }} 周</text>
      <text class="nav-arrow">▼</text>
    </view>
    <view class="nav-spacer"></view>
  </view>

  <view wx:if="{{loading}}" class="loading-overlay">
    <view class="loading-box">
      <text class="loading-text">导入课表中...</text>
    </view>
  </view>

  <view wx:if="{{showtip}}" class="menu-mask" catchtap="showtip">
    <view class="menu-panel" catchtap="noop">
      <view class="menu-title">课表操作</view>
      <view class="menu-item" catchtap="handleImportCourse">
        <view class="ios-icon icon-time menu-icon"></view>
        <text>导入课表</text>
      </view>
      <view class="menu-item" catchtap="handleRefreshCourse">
        <view class="ios-icon icon-refresh menu-icon"></view>
        <text>刷新课表</text>
      </view>
      <view class="menu-item danger" catchtap="handleClearCourse">
        <view class="ios-icon icon-close menu-icon"></view>
        <text>清空课表</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="schedule-scroll" enable-flex>
    <view class="week-selector-wrapper" wx:if="{{showpoint}}">
      <scroll-view scroll-x scroll-with-animation class="week-selector" enable-flex>
        <view
          class="week-item {{currentWeek === item ? 'active' : ''}}"
          wx:for="{{weekNumbers}}"
          wx:key="*this"
          bindtap="onPoint"
          data-week="{{item}}"
        >
          <text>第{{ item }}周</text>
        </view>
      </scroll-view>
    </view>

    <view class="schedule-head flex-row">
      <view class="head-left flex-column j_c">
        <view class="head-pin"></view>
        <text class="head-left-text one">第</text>
        <text class="head-left-text two">周</text>
        <text class="head-curr-week">{{currentWeek}}</text>
      </view>
      <view class="head-right flex-row j_b">
        <view class="flex-column j_c" wx:for="{{weekList}}" wx:key="week">
          <text class="head-week {{item.isCurr ? 'head-right-curr' : ''}}">{{item.week}}</text>
          <text class="{{item.isCurr ? 'head-right-curr' : ''}}">{{item.isCurr ? '今天' : item.day}}</text>
        </view>
      </view>
    </view>

    <view class="container flex-row mb20">
      <view class="container-left flex-column j_b">
        <block wx:for="{{time.one}}" wx:key="index">
          <view class="time-cell flex-column j_c">
            <text class="con-title">{{item.index}}</text>
            <text>{{item.timeStart}}</text>
            <text>{{item.timeEnd}}</text>
          </view>
        </block>
      </view>
      <view class="container-right flex-column j_c">
        <view class="flex-row mb10">
          <view
            class="con-item flex-column j_c {{item.type ? '' : 'empty-course'}}"
            wx:for="{{schedule.one}}"
            wx:key="index"
            style="background: {{item.color}};"
            catchtap="getDetail"
            data-item="{{item}}"
          >
            <text class="con-item-subj line-ellipsis">{{item.sub}}</text>
            <text class="line-ellipsis">{{item.tec}}</text>
            <text class="line-ellipsis">{{item.add}}</text>
          </view>
        </view>
        <view class="flex-row">
          <view
            class="con-item flex-column j_c {{item.type ? '' : 'empty-course'}}"
            wx:for="{{schedule.two}}"
            wx:key="index"
            style="background: {{item.color}};"
            catchtap="getDetail"
            data-item="{{item}}"
          >
            <text class="con-item-subj line-ellipsis">{{item.sub}}</text>
            <text class="line-ellipsis">{{item.tec}}</text>
            <text class="line-ellipsis">{{item.add}}</text>
          </view>
        </view>
        <view class="con-corner"></view>
      </view>
    </view>

    <view class="container flex-row mb20">
      <view class="container-left left-small flex-column j_b">
        <block wx:for="{{time.two}}" wx:key="index">
          <view class="time-cell flex-column j_c">
            <text class="con-title">{{item.index}}</text>
            <text>{{item.timeStart}}</text>
            <text>{{item.timeEnd}}</text>
          </view>
        </block>
      </view>
      <view class="container-right right-small flex-column j_c">
        <view class="flex-row">
          <view
            class="con-item flex-column j_c {{item.type ? '' : 'empty-course'}}"
            wx:for="{{schedule.three}}"
            wx:key="index"
            style="background: {{item.color}};"
            catchtap="getDetail"
            data-item="{{item}}"
          >
            <text class="con-item-subj line-ellipsis">{{item.sub}}</text>
            <text class="line-ellipsis">{{item.tec}}</text>
            <text class="line-ellipsis">{{item.add}}</text>
          </view>
        </view>
        <view class="con-corner"></view>
      </view>
    </view>

    <view class="container flex-row">
      <view class="container-left left-small flex-column j_b">
        <block wx:for="{{time.three}}" wx:key="index">
          <view class="time-cell flex-column j_c">
            <text class="con-title">{{item.index}}</text>
            <text>{{item.timeStart}}</text>
            <text>{{item.timeEnd}}</text>
          </view>
        </block>
      </view>
      <view class="container-right right-small flex-column j_c">
        <view class="flex-row">
          <view
            class="con-item flex-column j_c {{item.type ? '' : 'empty-course'}}"
            wx:for="{{schedule.four}}"
            wx:key="index"
            style="background: {{item.color}};"
            catchtap="getDetail"
            data-item="{{item}}"
          >
            <text class="con-item-subj line-ellipsis">{{item.sub}}</text>
            <text class="line-ellipsis">{{item.tec}}</text>
            <text class="line-ellipsis">{{item.add}}</text>
          </view>
        </view>
        <view class="con-corner"></view>
      </view>
    </view>

    <view wx:if="{{courses.length === 0}}" class="empty-state">
      <text class="empty-title">暂无课表</text>
      <text class="empty-desc">请先导入课表后再发布代课任务</text>
      <button class="empty-btn" bindtap="importCourse">导入课表</button>
    </view>
  </scroll-view>

  <view class="detail-mask" wx:if="{{isShow}}" catchtap="close"></view>
  <view
    wx:if="{{isShow}}"
    class="course-modal {{isShow ? 'show' : ''}}"
    style="background: {{current.color}};"
    catchtap="noop"
  >
    <view class="modal-course-name">{{current.sub}}</view>
    <view class="modal-row">教师：{{current.tec}}</view>
    <view class="modal-row">地点：{{current.add}}</view>
    <view class="modal-row">时间：第{{currentWeek}}周 {{current.timeLabel}}</view>
    <view class="modal-actions">
      <button class="modal-btn ghost" catchtap="close">取消</button>
      <button class="modal-btn solid" catchtap="publishSubstitute">发布</button>
    </view>
  </view>
</view>
