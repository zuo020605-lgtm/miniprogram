page {
  background: #f5f7fa;
}

.schedule-page {
  min-height: 100vh;
  background: #f5f7fa;
  overflow-x: hidden;
}

.schedule-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  height: 96rpx;
  padding: 0 24rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.nav-action-btn,
.nav-week,
.nav-spacer {
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-action-btn {
  min-width: 176rpx;
  height: 60rpx;
  gap: 10rpx;
  border-radius: 30rpx;
  color: #ffffff;
  background: #005da4;
  box-shadow: 0 6rpx 18rpx rgba(0, 93, 164, 0.22);
  font-weight: 800;
}

.nav-action-icon {
  font-size: 26rpx;
  line-height: 1;
}

.nav-action-text {
  font-size: 24rpx;
}

.nav-week {
  gap: 8rpx;
  color: #2c2f32;
  font-size: 30rpx;
  font-weight: 700;
}

.nav-arrow {
  color: #74777a;
  font-size: 18rpx;
}

.nav-spacer {
  width: 176rpx;
  height: 60rpx;
}

.schedule-scroll {
  height: calc(100vh - 96rpx);
  box-sizing: border-box;
  padding: 24rpx 20rpx 56rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.j_c {
  align-items: center;
  justify-content: center;
}

.j_b {
  align-items: center;
  justify-content: space-between;
}

.mb20 {
  margin-bottom: 20rpx;
}

.mb10 {
  margin-bottom: 10rpx;
}

.schedule-head {
  margin-bottom: 20rpx;
}

.head-left {
  position: relative;
  width: 90rpx;
  height: 125rpx;
  margin-right: 10rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 18rpx rgba(0, 93, 164, 0.08);
}

.head-pin {
  position: absolute;
  width: 38rpx;
  height: 38rpx;
  top: -10rpx;
  left: -10rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #005da4 0%, #23a6d5 100%);
  box-shadow: 0 4rpx 10rpx rgba(0, 93, 164, 0.24);
}

.head-left-text {
  position: absolute;
  color: #74777a;
  font-size: 22rpx;
}

.head-left-text.one {
  right: 10rpx;
  top: 8rpx;
}

.head-left-text.two {
  left: 10rpx;
  bottom: 8rpx;
}

.head-curr-week {
  font-size: 36rpx;
  color: #2c2f32;
  font-weight: 800;
  font-style: italic;
}

.head-right {
  flex: 1;
  height: 125rpx;
  padding: 0 14rpx;
  border-radius: 20rpx;
  background: #ffffff;
  color: #74777a;
  font-size: 23rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 18rpx rgba(0, 0, 0, 0.05);
}

.head-week {
  margin-bottom: 10rpx;
  color: #2c2f32;
  font-weight: 800;
}

.head-right-curr {
  color: #005da4;
}

.container {
  width: 100%;
}

.container-left {
  width: 90rpx;
  height: 500rpx;
  padding: 20rpx 0;
  margin-right: 10rpx;
  border-radius: 20rpx;
  background: #ffffff;
  color: #74777a;
  font-size: 22rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 18rpx rgba(0, 0, 0, 0.05);
}

.container-right {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 500rpx;
  padding: 20rpx 10rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 4rpx 18rpx rgba(0, 0, 0, 0.05);
}

.left-small,
.right-small {
  height: 250rpx;
}

.time-cell {
  flex: 1;
  line-height: 1.35;
}

.con-title {
  margin-bottom: 6rpx;
  color: #2c2f32;
  font-size: 28rpx;
  font-weight: 800;
  font-style: italic;
}

.con-item {
  width: calc((100vw - 160rpx) / 5);
  height: 225rpx;
  margin-right: 7rpx;
  padding: 10rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 30rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 18rpx rgba(0, 93, 164, 0.14);
  animation: courseShow 360ms ease;
}

.con-item:last-child {
  margin-right: 0;
}

.empty-course {
  box-shadow: inset 0 0 0 2rpx #eef2f7;
}

.con-item-subj {
  margin-bottom: 6rpx;
  font-size: 20rpx;
  font-weight: 800;
}

.line-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.con-corner {
  position: absolute;
  right: -10rpx;
  bottom: -10rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(0, 93, 164, 0.95), rgba(35, 166, 213, 0.95));
  box-shadow: 0 4rpx 14rpx rgba(0, 93, 164, 0.25);
}

@keyframes courseShow {
  0% {
    opacity: 0;
    transform: translateX(20rpx);
  }
  100% {
    opacity: 1;
    transform: translateX(0);
  }
}

.week-selector-wrapper {
  margin-bottom: 20rpx;
  padding: 14rpx 0;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.week-selector {
  white-space: nowrap;
  padding: 0 18rpx;
}

.week-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  height: 56rpx;
  margin-right: 12rpx;
  border-radius: 28rpx;
  background: #f5f7fa;
  color: #74777a;
  font-size: 24rpx;
  font-weight: 700;
}

.week-item.active {
  background: #005da4;
  color: #ffffff;
}

.loading-overlay,
.menu-mask,
.detail-mask {
  position: fixed;
  z-index: 300;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.42);
}

.loading-overlay {
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-box {
  padding: 32rpx 48rpx;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.78);
}

.loading-text {
  color: #ffffff;
  font-size: 28rpx;
}

.menu-mask {
  display: flex;
  align-items: flex-end;
}

.menu-panel {
  width: 100%;
  padding: 32rpx 24rpx 48rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.menu-title {
  margin-bottom: 24rpx;
  text-align: center;
  color: #2c2f32;
  font-size: 32rpx;
  font-weight: 800;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  height: 88rpx;
  padding: 0 24rpx;
  margin-bottom: 12rpx;
  border-radius: 20rpx;
  background: #f5f7fa;
  color: #2c2f32;
  font-size: 28rpx;
  font-weight: 700;
}

.menu-item.danger {
  color: #b31b25;
  background: rgba(179, 27, 37, 0.08);
}

.menu-icon {
  min-width: 40rpx;
  text-align: center;
}

.course-modal {
  position: fixed;
  z-index: 400;
  left: 50%;
  top: 50%;
  width: 590rpx;
  min-height: 360rpx;
  padding: 36rpx;
  border-radius: 28rpx;
  color: #ffffff;
  box-sizing: border-box;
  transform: translate(-50%, -44%);
  opacity: 0;
  transition: all 260ms ease;
  box-shadow: 0 20rpx 64rpx rgba(0, 0, 0, 0.2);
}

.course-modal.show {
  opacity: 1;
  transform: translate(-50%, -50%);
}

.modal-course-name {
  margin-bottom: 22rpx;
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 800;
}

.modal-row {
  margin-bottom: 12rpx;
  font-size: 27rpx;
  line-height: 1.5;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.modal-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 800;
  border: none;
}

.modal-btn::after {
  border: none;
}

.modal-btn.ghost {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.18);
}

.modal-btn.solid {
  color: #005da4;
  background: #ffffff;
}

.empty-state {
  margin: 36rpx 0 80rpx;
  padding: 56rpx 36rpx;
  border-radius: 24rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 4rpx 18rpx rgba(0, 0, 0, 0.05);
}

.empty-title,
.empty-desc {
  display: block;
}

.empty-title {
  color: #2c2f32;
  font-size: 32rpx;
  font-weight: 800;
}

.empty-desc {
  margin-top: 12rpx;
  color: #74777a;
  font-size: 24rpx;
}

.empty-btn {
  width: 260rpx;
  height: 78rpx;
  margin-top: 32rpx;
  border-radius: 18rpx;
  background: #005da4;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.empty-btn::after {
  border: none;
}
