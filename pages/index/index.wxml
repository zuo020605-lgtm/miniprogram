<scroll-view class="home-page" scroll-y enable-flex type="list">
  <!-- 顶部导航 - Glass Header -->
  <view class="header glass-header">
    <view class="campus-selector" bindtap="showCampusPicker">
      <view class="ios-icon icon-school"></view>
      <view class="campus-info">
        <text class="campus-label">当前校区</text>
        <view class="campus-name-wrapper">
          <text class="campus-name">{{ currentCampus }}</text>
          <text class="icon-chevron">→</text>
        </view>
      </view>
    </view>
    <view class="header-actions">
      <view class="notification-btn" bindtap="navigateToMessage">
        <view class="ios-icon icon-bell"></view>
        <view class="notification-badge" wx:if="{{unreadCount > 0}}">{{ unreadCount }}</view>
      </view>
      <view class="user-avatar" bindtap="navigateToProfile">
        <text class="avatar-text">AP</text>
      </view>
    </view>
  </view>

  <!-- Hero Search Section -->
  <view class="hero-section">
    <view class="hero-title">
      <text>你好，同学。</text>
      <text class="text-primary">今天需要什么帮助？</text>
    </view>
    <view class="search-wrapper">
      <view class="search-icon-wrapper">
        <view class="ios-icon icon-search search-icon"></view>
      </view>
      <input 
        type="text" 
        placeholder="搜索校园任务..." 
        value="{{searchKeyword}}" 
        bindinput="onSearchKeywordChange"
        bindconfirm="handleSearch"
        bindfocus="onSearchFocus"
        bindblur="onSearchBlur"
        class="search-input"
        confirm-type="search"
      />
    </view>
    <view class="search-history-panel" wx:if="{{showSearchHistory && searchHistory.length > 0}}">
      <view class="search-history-header">
        <text class="search-history-title">搜索历史</text>
        <text class="search-history-clear" catchtap="clearSearchHistory">清空</text>
      </view>
      <view class="search-history-list">
        <view
          class="search-history-item"
          wx:for="{{searchHistory}}"
          wx:key="*this"
          catchtap="selectSearchHistory"
          data-keyword="{{item}}"
        >
          <text class="history-clock">⌕</text>
          <text class="history-keyword">{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Campus Bulletin -->
  <view class="bulletin-panel ios-glass">
    <view class="bulletin-icon-wrap">
      <view class="ios-icon icon-bell bulletin-icon"></view>
    </view>
    <view class="bulletin-copy">
      <text class="bulletin-title">校园公告</text>
      <text class="bulletin-desc">夜间跑腿请优先选择校内认证接单员，发布任务前确认地点和联系方式。</text>
    </view>
    <view class="bulletin-orbit"></view>
  </view>

  <!-- Function Grid: Bento Style -->
  <view class="function-section">
    <view class="bento-grid">
      <!-- 校园代课 - 大卡片 -->
      <view class="bento-item bento-item-large gradient-primary" bindtap="navigateToCampusClass">
        <view class="ios-icon icon-class bento-icon-large"></view>
        <view class="bento-info">
          <text class="bento-title">校园代课</text>
          <text class="bento-subtitle">知识共享</text>
        </view>
      </view>
      
      <!-- 右侧小卡片组 -->
      <view class="bento-item-group">
        <!-- 校园跑腿 -->
        <view class="bento-item bento-item-small bg-secondary-container" bindtap="navigateToPublish" data-type="campus-errand">
          <view class="icon-wrapper-white">
            <view class="ios-icon icon-run bento-icon"></view>
          </view>
          <view class="bento-info-small">
            <text class="bento-title-small text-on-secondary-container">校园跑腿</text>
            <text class="bento-subtitle-small text-on-secondary-container-70">快速跑腿</text>
          </view>
        </view>
        
        <!-- 快递代取 -->
        <view class="bento-item bento-item-small bg-surface-container-highest" bindtap="navigateToPublish" data-type="express">
          <view class="icon-wrapper-white">
            <view class="ios-icon icon-package bento-icon"></view>
          </view>
          <view class="bento-info-small">
            <text class="bento-title-small text-on-surface">快递代取</text>
            <text class="bento-subtitle-small text-on-surface-variant">包裹代取</text>
          </view>
        </view>
      </view>
      
      <!-- 考试代替 - 全宽卡片 -->
      <view class="bento-item bento-item-full bg-tertiary-container" bindtap="navigateToPublish" data-type="exam">
        <view class="bento-full-left">
          <view class="icon-wrapper-tertiary">
            <view class="ios-icon icon-exam bento-icon"></view>
          </view>
          <view class="bento-info">
            <text class="bento-title text-on-tertiary-container">考试代替</text>
            <text class="bento-subtitle text-on-tertiary-container-80">考试周支持</text>
          </view>
        </view>
        <text class="chevron-right">→</text>
      </view>
    </view>
  </view>

  <!-- Quick Links -->
  <view class="quick-section">
    <view class="section-row">
      <text class="section-heading">快捷入口</text>
      <text class="section-action" bindtap="navigateToOrder">查看订单</text>
    </view>
    <scroll-view scroll-x class="quick-scroll" enable-flex>
      <view class="quick-list">
        <view class="quick-chip" bindtap="navigateToOrder">
          <view class="ios-icon icon-order quick-icon"></view>
          <text>订单进度</text>
        </view>
        <view class="quick-chip" bindtap="navigateToMessage">
          <view class="ios-icon icon-message quick-icon"></view>
          <text>消息</text>
        </view>
        <view class="quick-chip" bindtap="navigateToCampusClass">
          <view class="ios-icon icon-class quick-icon"></view>
          <text>课程</text>
        </view>
        <view class="quick-chip" bindtap="navigateToProfile">
          <view class="ios-icon icon-profile quick-icon"></view>
          <text>我的</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- Runner CTA -->
  <view class="runner-panel">
    <view class="runner-copy">
      <view class="runner-kicker">
        <view class="runner-dot"></view>
        <text>校园接单</text>
      </view>
      <text class="runner-title">加入校内跑腿队列</text>
      <text class="runner-desc">课间取件、资料递送、考试周支持，按地点和时间快速发布。</text>
      <button class="runner-action" bindtap="navigateToPublish">发布任务</button>
    </view>
    <view class="runner-visual" wx:if="{{featureImageVisible}}">
      <image class="runner-image" src="{{featureImage}}" mode="aspectFill" binderror="onFeatureImageError"></image>
    </view>
    <view class="runner-visual runner-visual-fallback" wx:else>
      <view class="ios-icon icon-run runner-fallback-icon"></view>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom" style="height: 180rpx;"></view>
</scroll-view>

<!-- Floating Action Button -->
<view class="fab-button" bindtap="navigateToPublish">
  <view class="ios-icon icon-plus fab-icon"></view>
</view>
