page {
  background: #f6f6fb;
}

.home-page {
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
  background:
    radial-gradient(circle at 12% -8%, rgba(0, 88, 187, 0.14), rgba(0, 88, 187, 0) 32%),
    radial-gradient(circle at 94% 8%, rgba(38, 185, 154, 0.12), rgba(38, 185, 154, 0) 30%),
    linear-gradient(180deg, #f6f6fb 0%, #eef3f9 100%);
}

.text-primary {
  color: var(--ios-tint, #0058bb);
}

.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-top: calc(var(--status-bar-height, 44rpx) + 24rpx);
  background: rgba(255, 255, 255, 0.74);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.78);
  box-shadow: 0 20rpx 50rpx rgba(22, 38, 58, 0.08);
  -webkit-backdrop-filter: blur(28px) saturate(180%);
  backdrop-filter: blur(28px) saturate(180%);
}

.campus-selector,
.notification-btn,
.user-avatar,
.bento-item,
.quick-chip,
.runner-action,
.fab-button {
  transition: transform 180ms cubic-bezier(0.2, 0.8, 0.2, 1), opacity 180ms ease, box-shadow 220ms ease;
}

.campus-selector:active,
.notification-btn:active,
.user-avatar:active,
.bento-item:active,
.quick-chip:active,
.runner-action:active,
.fab-button:active {
  transform: scale(0.94);
  opacity: 0.82;
}

.campus-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.campus-info {
  display: flex;
  flex-direction: column;
}

.campus-label {
  color: var(--ios-text-soft, #5a5b60);
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.campus-name-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.campus-name {
  color: var(--ios-text, #2d2f33);
  font-size: 32rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.icon-chevron {
  color: var(--ios-tint, #0058bb);
  font-size: 28rpx;
  font-weight: 800;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.notification-btn,
.user-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), 0 12rpx 28rpx rgba(22, 38, 58, 0.08);
}

.notification-btn {
  position: relative;
}

.notification-badge {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #0a84ff;
  color: #fff;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 28rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(10, 132, 255, 0.28);
}

.user-avatar {
  background: linear-gradient(135deg, #0a84ff 0%, #55b7ff 54%, #26b99a 100%);
}

.avatar-text {
  color: #fff;
  font-size: 22rpx;
  font-weight: 900;
}

.hero-section,
.bulletin-panel,
.function-section,
.quick-section,
.runner-panel {
  animation: ios-home-rise 420ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

@keyframes ios-home-rise {
  0% { opacity: 0; transform: translateY(18rpx) scale(0.99); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

.hero-section {
  padding: 52rpx 32rpx 28rpx;
}

.hero-title {
  display: flex;
  flex-direction: column;
  margin-bottom: 32rpx;
  color: var(--ios-text, #2d2f33);
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.08;
  letter-spacing: 0;
}

.search-wrapper {
  position: relative;
  z-index: 30;
  display: flex;
  align-items: center;
}

.search-icon-wrapper {
  position: absolute;
  left: 26rpx;
  z-index: 2;
  display: flex;
  align-items: center;
}

.search-icon {
  width: 34rpx;
  height: 34rpx;
  color: var(--ios-text-muted, #8792a1);
}

.search-input {
  width: 100%;
  height: 96rpx;
  padding: 0 28rpx 0 82rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  color: var(--ios-text, #2d2f33);
  font-size: 28rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.88), 0 14rpx 38rpx rgba(22, 38, 58, 0.08);
}

.search-history-panel {
  position: relative;
  z-index: 25;
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 44rpx rgba(22, 38, 58, 0.11);
}

.search-history-header,
.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.search-history-title,
.section-heading {
  color: var(--ios-text, #2d2f33);
  font-size: 30rpx;
  font-weight: 900;
}

.search-history-clear,
.section-action {
  color: var(--ios-tint, #0058bb);
  font-size: 24rpx;
  font-weight: 800;
}

.search-history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.search-history-item {
  max-width: 100%;
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(0, 88, 187, 0.08);
  color: var(--ios-tint, #0058bb);
}

.history-clock,
.history-keyword {
  font-size: 24rpx;
  font-weight: 700;
}

.history-keyword {
  max-width: 520rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bulletin-panel {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin: 0 32rpx 28rpx;
  padding: 26rpx;
  overflow: hidden;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.52);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  box-shadow: 0 20rpx 50rpx rgba(22, 38, 58, 0.08);
  -webkit-backdrop-filter: blur(26px) saturate(180%);
  backdrop-filter: blur(26px) saturate(180%);
}

.bulletin-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 88, 187, 0.1);
  color: var(--ios-tint, #0058bb);
  flex-shrink: 0;
}

.bulletin-copy {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bulletin-title {
  color: var(--ios-text, #2d2f33);
  font-size: 28rpx;
  font-weight: 900;
}

.bulletin-desc {
  color: var(--ios-text-soft, #5a5b60);
  font-size: 24rpx;
  line-height: 1.55;
}

.bulletin-orbit {
  position: absolute;
  right: -42rpx;
  top: -54rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(0, 88, 187, 0.08);
  filter: blur(20rpx);
}

.function-section,
.quick-section,
.runner-panel {
  margin: 0 32rpx 32rpx;
}

.bento-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
}

.bento-item {
  position: relative;
  overflow: hidden;
  border-radius: 34rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 18rpx 44rpx rgba(22, 38, 58, 0.08);
}

.bento-item-large {
  min-height: 286rpx;
  grid-row: span 2;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.gradient-primary {
  background: linear-gradient(145deg, #0058bb 0%, #0a84ff 58%, #55b7ff 100%);
}

.bento-icon-large {
  width: 76rpx;
  height: 76rpx;
  color: #fff;
}

.bento-info,
.bento-info-small {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bento-title {
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
}

.bento-subtitle {
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
  font-weight: 700;
}

.bento-item-group {
  grid-row: span 2;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.bento-item-small {
  flex: 1;
  min-height: 132rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.bg-secondary-container,
.bg-surface-container-highest,
.bg-tertiary-container {
  background: rgba(255, 255, 255, 0.82);
}

.icon-wrapper-white,
.icon-wrapper-tertiary {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 88, 187, 0.1);
  color: var(--ios-tint, #0058bb);
  flex-shrink: 0;
}

.bento-icon {
  width: 42rpx;
  height: 42rpx;
}

.bento-title-small {
  color: var(--ios-text, #2d2f33);
  font-size: 28rpx;
  font-weight: 900;
}

.bento-subtitle-small {
  color: var(--ios-text-soft, #5a5b60);
  font-size: 21rpx;
  font-weight: 700;
}

.bento-item-full {
  grid-column: span 2;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bento-full-left {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.text-on-tertiary-container,
.text-on-surface,
.text-on-secondary-container {
  color: var(--ios-text, #2d2f33);
}

.text-on-tertiary-container-80,
.text-on-surface-variant,
.text-on-secondary-container-70 {
  color: var(--ios-text-soft, #5a5b60);
}

.chevron-right {
  color: var(--ios-tint, #0058bb);
  font-size: 34rpx;
  font-weight: 900;
}

.quick-section {
  padding-top: 4rpx;
}

.quick-scroll {
  width: 100%;
  margin-top: 22rpx;
  white-space: nowrap;
}

.quick-list {
  display: flex;
  gap: 18rpx;
  padding-bottom: 4rpx;
}

.quick-chip {
  flex-shrink: 0;
  height: 76rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  color: var(--ios-text, #2d2f33);
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 12rpx 32rpx rgba(22, 38, 58, 0.06);
}

.quick-icon {
  width: 34rpx;
  height: 34rpx;
  color: var(--ios-tint, #0058bb);
}

.runner-panel {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 240rpx;
  padding: 32rpx;
  overflow: hidden;
  border-radius: 42rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 24rpx 60rpx rgba(22, 38, 58, 0.1);
}

.runner-copy {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.runner-kicker {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(0, 88, 187, 0.1);
  color: var(--ios-tint, #0058bb);
  font-size: 20rpx;
  font-weight: 900;
}

.runner-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--ios-tint, #0058bb);
}

.runner-title {
  color: var(--ios-text, #2d2f33);
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.16;
}

.runner-desc {
  max-width: 390rpx;
  color: var(--ios-text-soft, #5a5b60);
  font-size: 23rpx;
  line-height: 1.5;
}

.runner-action {
  align-self: flex-start;
  min-width: 172rpx;
  height: 72rpx;
  margin: 6rpx 0 0;
  padding: 0 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #0058bb 0%, #0a84ff 100%);
  color: #fff;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 72rpx;
  box-shadow: 0 16rpx 34rpx rgba(10, 132, 255, 0.24);
}

.runner-visual {
  width: 154rpx;
  height: 154rpx;
  border-radius: 36rpx;
  overflow: hidden;
  flex-shrink: 0;
  transform: rotate(3deg);
  box-shadow: 0 22rpx 44rpx rgba(22, 38, 58, 0.18);
}

.runner-image {
  width: 100%;
  height: 100%;
}

.runner-visual-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(0, 88, 187, 0.13), rgba(38, 185, 154, 0.14));
  color: var(--ios-tint, #0058bb);
}

.runner-fallback-icon {
  width: 80rpx;
  height: 80rpx;
}

.fab-button {
  position: fixed;
  right: 32rpx;
  bottom: calc(128rpx + env(safe-area-inset-bottom));
  z-index: 110;
  width: 108rpx;
  height: 108rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 88, 187, 0.9);
  color: #fff;
  box-shadow: 0 20rpx 44rpx rgba(0, 88, 187, 0.28);
  -webkit-backdrop-filter: blur(18px);
  backdrop-filter: blur(18px);
}

.fab-icon {
  width: 56rpx;
  height: 56rpx;
  color: #fff;
}

@media (prefers-color-scheme: dark) {
  .home-page {
    background:
      radial-gradient(circle at 12% -8%, rgba(10, 132, 255, 0.2), rgba(10, 132, 255, 0) 32%),
      linear-gradient(180deg, #0e141c 0%, #151f2b 100%);
  }

  .header,
  .bulletin-panel,
  .bento-item,
  .quick-chip,
  .runner-panel {
    background-color: rgba(24, 34, 48, 0.78);
    border-color: rgba(255, 255, 255, 0.12);
  }
}

/* iOS26 visual QA pass: stronger contrast and warmer accents. */
.home-page {
  background:
    radial-gradient(circle at 10% -8%, rgba(10, 132, 255, 0.2), rgba(10, 132, 255, 0) 34%),
    radial-gradient(circle at 88% 10%, rgba(255, 195, 80, 0.2), rgba(255, 195, 80, 0) 28%),
    radial-gradient(circle at 20% 88%, rgba(46, 196, 182, 0.16), rgba(46, 196, 182, 0) 34%),
    linear-gradient(180deg, #f7f9fd 0%, #eef4f8 52%, #f7f0ec 100%);
}

.home-page .header {
  background: rgba(249, 252, 255, 0.96) !important;
  -webkit-backdrop-filter: none !important;
  backdrop-filter: none !important;
  border-bottom-color: rgba(0, 88, 187, 0.1) !important;
}

.home-page .campus-selector {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(232, 246, 255, 0.82)) !important;
  border: 1rpx solid rgba(0, 88, 187, 0.12) !important;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.96), 0 10rpx 24rpx rgba(22, 38, 58, 0.08) !important;
  color: #2d2f33 !important;
}

.home-page .bento-item-large.gradient-primary {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.96) 0%, rgba(218, 239, 255, 0.9) 48%, rgba(221, 250, 242, 0.86) 100%) !important;
  border: 1rpx solid rgba(0, 88, 187, 0.14) !important;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.96), 0 18rpx 46rpx rgba(10, 132, 255, 0.16) !important;
}

.home-page .bento-item-large .bento-icon-large {
  color: #0058bb !important;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(0, 88, 187, 0.16);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.96), 0 12rpx 28rpx rgba(0, 88, 187, 0.14);
}

.home-page .bento-item-large .bento-title {
  color: #1f2937 !important;
}

.home-page .bento-item-large .bento-subtitle {
  color: #59636f !important;
}

.home-page .bg-secondary-container {
  background: linear-gradient(145deg, rgba(229, 255, 248, 0.96), rgba(197, 244, 236, 0.86)) !important;
  border-color: rgba(38, 185, 154, 0.18) !important;
}

.home-page .bg-surface-container-highest {
  background: linear-gradient(145deg, rgba(255, 247, 225, 0.96), rgba(255, 232, 181, 0.78)) !important;
  border-color: rgba(218, 143, 0, 0.16) !important;
}

.home-page .bg-tertiary-container {
  background: linear-gradient(145deg, rgba(255, 237, 234, 0.96), rgba(255, 216, 208, 0.84)) !important;
  border-color: rgba(255, 111, 97, 0.18) !important;
}

.home-page .quick-chip {
  background: rgba(255, 255, 255, 0.9) !important;
  border: 1rpx solid rgba(0, 88, 187, 0.12) !important;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.96), 0 10rpx 26rpx rgba(22, 38, 58, 0.08) !important;
}

.home-page .quick-chip:nth-child(2) {
  border-color: rgba(255, 111, 97, 0.18) !important;
  background: rgba(255, 242, 240, 0.9) !important;
}

.home-page .quick-chip:nth-child(3) {
  border-color: rgba(38, 185, 154, 0.18) !important;
  background: rgba(230, 250, 245, 0.9) !important;
}

.home-page .quick-chip:nth-child(4) {
  border-color: rgba(218, 143, 0, 0.18) !important;
  background: rgba(255, 247, 225, 0.9) !important;
}

/* Morandi palette refinement. */
.home-page {
  background:
    radial-gradient(circle at 10% -8%, rgba(96, 120, 137, 0.14), rgba(96, 120, 137, 0) 34%),
    radial-gradient(circle at 88% 12%, rgba(129, 148, 135, 0.12), rgba(129, 148, 135, 0) 28%),
    linear-gradient(180deg, #f3f5f6 0%, #e8edf0 100%) !important;
}

.home-page .text-primary,
.home-page .section-action,
.home-page .icon-chevron,
.home-page .quick-icon {
  color: #607889 !important;
}

.home-page .bulletin-panel {
  background: rgba(250, 252, 251, 0.92) !important;
  border: 1rpx solid rgba(105, 124, 134, 0.18) !important;
  box-shadow: 0 14rpx 36rpx rgba(58, 70, 76, 0.1) !important;
}

.home-page .bulletin-panel text,
.home-page .bulletin-title,
.home-page .bulletin-desc,
.home-page .bulletin-copy {
  color: #485156 !important;
}

.home-page .bulletin-title {
  color: #2f3538 !important;
}

.home-page .bulletin-icon-wrap,
.home-page .notification-btn,
.home-page .campus-selector {
  background: rgba(238, 243, 244, 0.96) !important;
  border: 1rpx solid rgba(105, 124, 134, 0.18) !important;
}

.home-page .bulletin-icon,
.home-page .notification-btn .ios-icon {
  color: #607889 !important;
}

.home-page .bulletin-orbit {
  display: none !important;
}

.home-page .user-avatar,
.home-page .fab-button,
.home-page .runner-action {
  background: linear-gradient(135deg, #607889 0%, #4f6675 100%) !important;
  color: #ffffff !important;
}

.home-page .bento-item-large.gradient-primary,
.home-page .bg-secondary-container,
.home-page .bg-surface-container-highest,
.home-page .bg-tertiary-container,
.home-page .quick-chip,
.home-page .runner-panel {
  background: rgba(253, 254, 253, 0.94) !important;
  border: 1rpx solid rgba(105, 124, 134, 0.18) !important;
  box-shadow: 0 14rpx 36rpx rgba(58, 70, 76, 0.1) !important;
}

.home-page .bento-item-large .bento-icon-large,
.home-page .icon-wrapper-white,
.home-page .icon-wrapper-tertiary,
.home-page .runner-visual-fallback {
  background: rgba(96, 120, 137, 0.12) !important;
  border: 1rpx solid rgba(96, 120, 137, 0.16) !important;
  color: #607889 !important;
}
