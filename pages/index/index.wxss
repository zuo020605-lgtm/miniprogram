/* ============================================
   首页样式 - Material Design 3
   ============================================ */

page {
  background-color: #f5f7fa;
}

.home-page {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 全局文字色 ========== */
/* [修复] 将 text-primary 从局部选择器改为全局类，全页通用 */
.text-primary {
  color: #005da4;
}

/* ========== 顶部导航 ========== */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-top: calc(var(--status-bar-height, 44rpx) + 24rpx);
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

/* [修复] 补充缺失的 glass-header 类定义（WXML 中使用但 CSS 中未定义） */
.glass-header {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.campus-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
  /* iOS 风格动画 */
  transition: opacity 0.1s ease;
}

.campus-selector:active {
  opacity: 0.6;
}

.icon-school {
  width: 48rpx;
  height: 48rpx;
}

.campus-info {
  display: flex;
  flex-direction: column;
}

.campus-label {
  font-size: 20rpx;
  color: #595c5e;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.campus-name-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.campus-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c2f32;
}

.icon-chevron {
  width: 24rpx;
  height: 24rpx;
  margin-left: 8rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.notification-btn {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  /* iOS 风格动画 */
  transition: transform 0.1s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.1s ease;
}

.notification-btn:active {
  transform: scale(0.85);
  opacity: 0.7;
}

.icon-bell {
  width: 28rpx;
  height: 28rpx;
}

.notification-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background-color: #b31b25;
  color: #ffefee;
  font-size: 18rpx;
  font-weight: 700;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #005da4 0%, #00518f 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 93, 164, 0.3);
  /* iOS 风格动画 */
  transition: transform 0.1s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.1s ease;
}

.user-avatar:active {
  transform: scale(0.88);
  opacity: 0.8;
}

.avatar-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #edf3ff;
}

/* ========== Hero Section ========== */
.hero-section {
  padding: 48rpx 32rpx 32rpx;
}

.hero-title {
  display: flex;
  flex-direction: column;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.2;
  color: #2c2f32;
  margin-bottom: 32rpx;
  letter-spacing: -0.02em;
}

.search-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.search-icon-wrapper {
  position: absolute;
  left: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  transition: opacity 0.2s ease;
}

.search-wrapper:focus-within .search-icon {
  opacity: 1;
}

.search-input {
  width: 100%;
  height: 96rpx;
  padding: 0 24rpx 0 80rpx;
  background-color: #ffffff;
  border: 2rpx solid transparent;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #2c2f32;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.search-input:focus {
  border-color: #005da4;
  box-shadow: 0 4rpx 24rpx rgba(0, 93, 164, 0.15);
}

.search-input::placeholder {
  color: #74777a;
}

/* ========== Bento Grid ========== */
.function-section {
  padding: 0 32rpx 32rpx;
}

.bento-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: auto auto;
  gap: 24rpx;
}

.bento-item {
  border-radius: 32rpx;
  /* iOS 风格动画 */
  transition: transform 0.1s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.1s ease;
}

.bento-item:active {
  transform: scale(0.94);
  opacity: 0.88;
}

/* 大卡片 - 校园代课 */
.bento-item-large {
  grid-row: span 2;
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(0, 93, 164, 0.25);
  align-self: stretch;
}

.gradient-primary {
  background: linear-gradient(135deg, #005da4 0%, #00518f 100%);
}

.bento-icon-large {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 16rpx;
}

.bento-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bento-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #edf3ff;
}

.bento-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 右侧小卡片组 */
/* [核心修复] 补充缺失的 .bento-item-group 样式：
   原来只有裸 <view> 包裹两个小卡片，没有任何 flex/gap 声明，
   导致两张卡片之间完全没有间距。
   同时需要 height: 100% 让它撑满左侧大卡片的高度，
   再用 flex: 1 让两张小卡片均分高度。 */
.bento-item-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  height: 100%;
  grid-row: span 2
}

.bento-item-small {
  flex: 1; /* 让两张小卡片均分 .bento-item-group 的高度 */
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.bg-secondary-container {
  background-color: #bfd1ff;
}

.bg-surface-container-highest {
  background-color: #d9dde1;
}

.icon-wrapper-white {
  width: 72rpx;
  height: 72rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

.bento-icon {
  width: 40rpx;
  height: 40rpx;
}

.bento-info-small {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.bento-title-small {
  font-size: 28rpx;
  font-weight: 700;
}

.bento-subtitle-small {
  font-size: 20rpx;
}

.text-on-secondary-container {
  color: #004496;
}

.text-on-secondary-container-70 {
  color: rgba(0, 68, 150, 0.7);
}

.text-on-surface {
  color: #2c2f32;
}

.text-on-surface-variant {
  color: #595c5e;
}

.text-secondary {
  color: #1658b6;
}

/* 全宽卡片 - 考试代替 */
/* [修复] 原来 .bento-item-full 定义了三次，合并为一次 */
.bento-item-full {
  grid-column: span 2;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(126, 63, 159, 0.15);
  border-radius: 32rpx;
  /* iOS 风格动画 */
  transition: transform 0.1s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.1s ease;
}

.bento-item-full:active {
  transform: scale(0.96);
  opacity: 0.88;
}

.bg-tertiary-container {
  background-color: #de98ff;
}

.bento-full-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.icon-wrapper-tertiary {
  width: 88rpx;
  height: 88rpx;
  background-color: rgba(255, 255, 255, 0.5);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.text-on-tertiary-container {
  color: #510d72;
}

.text-on-tertiary-container-80 {
  color: rgba(81, 13, 114, 0.8);
}

.text-tertiary {
  color: #7e3f9f;
}

.chevron-right {
  width: 40rpx;
  height: 40rpx;
  transform: rotate(90deg);
}

/* ========== Popular Tasks Section ========== */
.popular-tasks-section {
  padding: 32rpx 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #2c2f32;
  letter-spacing: -0.01em;
}

.section-more {
  font-size: 22rpx;
  font-weight: 700;
  color: #005da4;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  /* iOS 风格动画 */
  transition: opacity 0.1s ease;
}

.section-more:active {
  opacity: 0.5;
}

/* [修复] 补充缺失的 .no-scrollbar 类定义（WXML 中使用但 CSS 中未定义） */
.no-scrollbar::-webkit-scrollbar {
  display: none;
}

.tasks-scroll {
  display: flex;
  padding: 0 32rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.task-card {
  flex-shrink: 0;
  width: calc(100vw - 64rpx);
  max-width: calc(100vw - 64rpx);
  min-width: calc(100vw - 64rpx);
  padding: 32rpx;
  margin-bottom: 24rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
  /* [修复] 原来 transition 定义了两次，合并为一条 iOS 风格动画 */
  transition: transform 0.1s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.1s ease;
}

.task-card:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.task-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.task-tag {
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  font-size: 20rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.02em;
}

.tag-urgent {
  background-color: rgba(179, 27, 37, 0.1);
  color: #b31b25;
}

.tag-new {
  background-color: rgba(79, 164, 255, 0.15);
  color: #005da4;
}

.tag-success {
  background-color: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

.tag-warning {
  background-color: rgba(255, 152, 0, 0.1);
  color: #FF9800;
}

.task-price {
  font-size: 40rpx;
  font-weight: 800;
  color: #005da4;
}

.task-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c2f32;
  margin-bottom: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-meta {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-meta-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-icon {
  width: 28rpx;
  height: 28rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #595c5e;
}

/* 空状态卡片 */
.empty-card {
  flex-shrink: 0;
  width: calc(100vw - 64rpx);
  max-width: calc(100vw - 64rpx);
  min-width: calc(100vw - 64rpx);
  height: 280rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #e5e8ec;
  border-radius: 32rpx;
  gap: 16rpx;
  box-sizing: border-box;
}

.empty-icon {
  font-size: 64rpx;
  color: #74777a;
}

.empty-text {
  font-size: 28rpx;
  color: #595c5e;
}

/* ========== Latest Posts Section ========== */
.latest-posts-section {
  padding: 32rpx;
}

.posts-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.post-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  /* iOS 风格动画 */
  transition: transform 0.1s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.1s ease;
}

.post-item:active {
  transform: scale(0.97);
  opacity: 0.88;
}

.post-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bg-secondary-container-30 {
  background-color: rgba(191, 209, 255, 0.3);
}

.bg-tertiary-container-30 {
  background-color: rgba(222, 152, 255, 0.3);
}

.bg-primary-container-20 {
  background-color: rgba(79, 164, 255, 0.2);
}

.post-icon {
  width: 48rpx;
  height: 48rpx;
  object-fit: contain;
}

.post-content {
  flex: 1;
  min-width: 0;
}

.post-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.post-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2c2f32;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #005da4;
  flex-shrink: 0;
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  /* [修复] 移除 gap，用 meta-icon-small 的 margin-right 控制，避免双重间距 */
  font-size: 20rpx;
  color: #595c5e;
}

.meta-icon-small {
  width: 20rpx;
  height: 20rpx;
  /* [修复] 保留 margin-right，移除父级 gap 避免双重间距 */
  margin-right: 6rpx;
  flex-shrink: 0;
}

/* ========== Floating Action Button ========== */
.fab-button {
  position: fixed;
  right: 32rpx;
  bottom: calc(120rpx + constant(safe-area-inset-bottom));
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #005da4 0%, #00518f 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 93, 164, 0.35);
  z-index: 100;
  /* iOS 风格动画 */
  transition: transform 0.1s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.1s ease;
}

.fab-button:active {
  transform: scale(0.88);
  box-shadow: 0 4rpx 12rpx rgba(0, 93, 164, 0.25);
}

.fab-icon {
  width: 56rpx;
  height: 56rpx;
  transform: rotate(45deg);
}

/* ========== 骨架屏 ========== */
.skeleton-card {
  background-color: #e5e8ec;
}

.skeleton {
  background: linear-gradient(90deg, #e5e8ec 25%, #dfe3e7 50%, #e5e8ec 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 8rpx;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

.skeleton-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
  background: none;
  animation: none;
}

.skeleton-tag {
  width: 100rpx;
  height: 40rpx;
  border-radius: 20rpx;
}

.skeleton-price {
  width: 80rpx;
  height: 48rpx;
  border-radius: 8rpx;
}

.skeleton-title {
  width: 80%;
  height: 40rpx;
  margin-bottom: 24rpx;
}

.skeleton-info {
  width: 60%;
  height: 32rpx;
}

/* ========== Material Symbols 字体 ========== */
.material-symbols-outlined {
  font-family: 'Material Symbols Outlined';
  font-weight: normal;
  font-style: normal;
  font-size: 24rpx;
  line-height: 1;
  letter-spacing: normal;
  text-transform: none;
  display: inline-block;
  white-space: nowrap;
  word-wrap: normal;
  direction: ltr;
  -webkit-font-feature-settings: 'liga';
  -webkit-font-smoothing: antialiased;
  font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
}
