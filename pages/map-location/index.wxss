.map-location-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e5e5e5;
  position: relative;
  z-index: 10;
}

.header-left {
  width: 80rpx;
}

.header-back {
  font-size: 32rpx;
  color: #005da4;
}

.header-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.header-right {
  width: 80rpx;
  text-align: right;
}

.header-confirm {
  font-size: 28rpx;
  color: #005da4;
  font-weight: 500;
}

.map-container {
  flex: 1;
  position: relative;
}

.map {
  width: 100%;
  height: 100%;
}

.map-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 10;
  pointer-events: none;
}

.location-marker {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.marker-inner {
  width: 24rpx;
  height: 24rpx;
  background-color: #005da4;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.location-info {
  padding: 16rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  border-bottom: 1rpx solid #e5e5e5;
}

.location-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.location-address {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.4;
}

.search-bar {
  display: flex;
  padding: 16rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e5e5e5;
}

.search-input {
  flex: 1;
  height: 64rpx;
  padding: 0 20rpx;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.search-btn {
  width: 120rpx;
  height: 64rpx;
  background-color: #005da4;
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 28rpx;
  line-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-results {
  max-height: 400rpx;
  overflow-y: auto;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e5e5e5;
}

.result-item {
  padding: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.result-address {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.4;
}

/* 确认选择按钮 */
.confirm-button-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 20;
}

.confirm-button {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 100%);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
  transition: all 0.2s ease;
}

.confirm-button:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.2);
}