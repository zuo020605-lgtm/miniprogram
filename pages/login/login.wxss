.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 40rpx;
}

.login-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-card {
  background: white;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  width: 100%;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 40rpx;
}

.login-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  border: 4rpx solid #f0f0f0;
}

.nickname {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #07c160;
  color: white;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.login-btn::after {
  border: none;
}

.login-btn.loading {
  background-color: #95a5a6;
}

.tips {
  margin-top: 20rpx;
  text-align: center;
}

.error-text {
  color: #e74c3c;
  font-size: 24rpx;
}

.success-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.phone {
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #95a5a6;
  color: white;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.logout-btn::after {
  border: none;
}

.login-tips {
  text-align: center;
  color: #666;
  font-size: 24rpx;
}

.openid {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.debug-info {
  margin-top: 40rpx;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
}

.debug-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: block;
  color: #333;
}

.debug-info text {
  font-size: 24rpx;
  line-height: 1.5;
  color: #666;
}

.debug-buttons {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.debug-btn {
  background-color: #f0f0f0;
  color: #333;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
}

.debug-btn::after {
  border: none;
}