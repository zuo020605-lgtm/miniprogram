}

.order-page .main-tab-item.active,
.order-page .tab-item.active {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(219, 239, 255, 0.86)) !important;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.96), 0 10rpx 24rpx rgba(10, 132, 255, 0.12) !important;
}

.order-page .main-tab-item.active::after,
.order-page .tab-item.active::after {
  display: none !important;
}

.order-page .recent-order-card,
.order-page .order-card,
.order-page .order-item,
.order-page .runner-permission {
  background: rgba(255, 255, 255, 0.94) !important;
  border: 1rpx solid rgba(0, 88, 187, 0.12) !important;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.96), 0 18rpx 44rpx rgba(22, 38, 58, 0.1) !important;
}

.order-page .recent-route,
.order-page .order-courier {
  background: rgba(241, 247, 252, 0.96) !important;
  border: 1rpx solid rgba(0, 88, 187, 0.1) !important;
}

.order-page .btn-accept,
.order-page .permission-action,
.order-page .btn-primary,
.order-page .card-btn.primary,
.order-page .action-btn.btn-primary {
  background: linear-gradient(135deg, #0058bb 0%, #0a84ff 100%) !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow: 0 12rpx 28rpx rgba(0, 88, 187, 0.22) !important;
}

.order-page .btn-accept text,
.order-page .permission-action text,
.order-page .btn-primary text,
.order-page .card-btn.primary text,
.order-page .action-btn.btn-primary text {
  color: #ffffff !important;
}

.order-page .card-btn.secondary,
.order-page .btn-outline,
.order-page .action-btn.btn-outline {
  background: rgba(255, 255, 255, 0.9) !important;
  color: #0058bb !important;
  border: 1rpx solid rgba(0, 88, 187, 0.2) !important;
}

/* Morandi order layout pass. */
.order-page {
  background:
    radial-gradient(circle at 88% -4%, rgba(129, 148, 135, 0.12), rgba(129, 148, 135, 0) 30%),
    linear-gradient(180deg, #f3f5f6 0%, #e8edf0 100%) !important;
}

.order-page .main-tab-nav,
.order-page .tab-nav {
  gap: 14rpx;
  padding: 18rpx 24rpx !important;
  background: rgba(250, 252, 251, 0.9) !important;
  border-bottom: 1rpx solid rgba(105, 124, 134, 0.18) !important;
}

.order-page .main-tab-item,
.order-page .tab-item {
  min-width: 0;
  height: 72rpx;
  padding: 0 14rpx;
  border-radius: 22rpx;
}

.order-page .main-tab-label,
.order-page .tab-label,
.order-page .tab-text {
  color: #737e83 !important;
  font-size: 27rpx !important;
  font-weight: 700 !important;
  white-space: nowrap;
}

