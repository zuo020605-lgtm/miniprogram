.order-page .order-list {
  padding: 24rpx !important;
  display: flex !important;
  flex-direction: column !important;
  gap: 22rpx !important;
}

.order-page .recent-order-card,
.order-page .order-card {
  margin: 0 !important;
  padding: 28rpx !important;
  border-radius: 28rpx !important;
  background: rgba(253, 254, 253, 0.96) !important;
  border: 1rpx solid rgba(105, 124, 134, 0.18) !important;
  box-shadow: 0 16rpx 42rpx rgba(58, 70, 76, 0.1) !important;
}

.order-page .card-header,
.order-page .recent-card-header {
  display: flex !important;
  align-items: flex-start !important;
  gap: 18rpx !important;
  margin-bottom: 20rpx !important;
}

.order-page .service-badge {
  width: 64rpx !important;
  height: 64rpx !important;
  border-radius: 20rpx !important;
  flex: 0 0 64rpx !important;
  background: rgba(96, 120, 137, 0.12) !important;
  color: #607889 !important;
}

.order-page .card-title-wrap,
.order-page .recent-title-wrap {
  flex: 1 1 auto !important;
  min-width: 0 !important;
}

.order-page .card-title,
.order-page .recent-order-title {
  display: block !important;
  color: #2f3538 !important;
  font-size: 30rpx !important;
  font-weight: 780 !important;
  line-height: 1.35 !important;
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}

.order-page .card-meta,
.order-page .recent-order-type,
.order-page .meta-text {
  color: #737e83 !important;
  font-size: 23rpx !important;
  line-height: 1.4 !important;
}

.order-page .card-price,
.order-page .recent-price {
  flex: 0 0 auto !important;
  min-width: 116rpx;
  text-align: right;
  color: #4f6675 !important;
}

.order-page .price-symbol {
  font-size: 22rpx !important;
  color: #607889 !important;
}

.order-page .price-value {
  font-size: 34rpx !important;
  color: #4f6675 !important;
}

.order-page .card-body,
.order-page .recent-route {
  margin: 0 0 20rpx !important;
