<view class="page-container order-page">
  <!-- 顶部主视图 -->
  <view class="main-tab-nav">
    <view
      class="main-tab-item {{mainTab === 'recent' ? 'active' : ''}}"
      bindtap="switchMainTab"
      data-key="recent"
    >
      <text class="main-tab-label">最近发布</text>
    </view>
    <view
      class="main-tab-item {{mainTab === 'mine' ? 'active' : ''}}"
      bindtap="switchMainTab"
      data-key="mine"
    >
      <text class="main-tab-label">我的发布</text>
    </view>
  </view>

  <!-- 最近发布 -->
  <scroll-view
    wx:if="{{mainTab === 'recent'}}"
    scroll-y
    class="order-list-scroll"
    refresher-enabled
    refresher-triggered="{{isRefreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <view wx:if="{{!isRunner}}" class="runner-permission">
      <view class="permission-icon">
        <view class="ios-icon icon-lock icon-order-empty"></view>
      </view>
      <text class="permission-title">仅通过认证的接单员才可查看并接取任务</text>
      <text class="permission-desc">完成认证后，你可以在这里查看最近发布的可接任务。</text>
      <button class="permission-action" bindtap="navigateToRunnerAuth">申请认证</button>
    </view>

    <block wx:else>
      <view wx:if="{{recentLoading}}" class="skeleton-container">
        <view class="skeleton skeleton-card" wx:for="{{5}}" wx:key="index"></view>
      </view>

      <view wx:else class="recent-order-list">
        <view
          class="recent-order-card"
          wx:for="{{recentOrders}}"
          wx:key="_id"
          bindtap="navigateToOrderDetail"
          data-id="{{item._id}}"
          data-status="{{item.status}}"
          data-service-type="{{item.serviceType}}"
        >
          <view class="recent-card-header">
            <view class="recent-title-wrap">
              <text class="recent-order-title">{{ item.displayTitle }}</text>
              <text class="recent-order-type">{{ item.serviceTypeText }} · {{ item.createdAtText }}</text>
            </view>
            <view class="recent-price">
              <text class="price-symbol">¥</text>
              <text class="price-value">{{ item.price }}</text>
            </view>
          </view>

          <view class="recent-route">
            <view class="recent-route-row" wx:if="{{item.pickupText}}">
              <text class="route-label">取货</text>
              <text class="route-text">{{ item.pickupText }}</text>
            </view>
            <view class="recent-route-row" wx:if="{{item.deliveryText}}">
              <text class="route-label">送达</text>
              <text class="route-text">{{ item.deliveryText }}</text>
            </view>
            <view class="recent-route-row">
              <text class="route-label">发布</text>
              <text class="route-text">{{ item.publisherName }}</text>
            </view>
          </view>

          <view class="recent-card-footer">
            <text class="recent-order-id">订单编号：{{ item.orderNo || item._id }}</text>
            <button
              class="btn-accept"
              wx:if="{{item.status === 'PENDING'}}"
              catchtap="acceptOrder"
              data-id="{{item._id}}"
            >立即接单</button>
            <text class="badge-accepted" wx:else>已接单</text>
          </view>
        </view>

        <view wx:if="{{recentOrders.length === 0}}" class="empty-container">
          <view class="empty-visual">
            <view class="ios-icon icon-order icon-order-empty"></view>
          </view>
          <text class="empty-title">暂无最近发布</text>
          <text class="empty-desc">当前没有可接取的任务</text>
        </view>
      </view>
    </block>
  </scroll-view>

  <!-- 我的发布 -->
  <view wx:if="{{mainTab === 'mine'}}" class="mine-panel">
    <!-- 订单状态选项卡 -->
    <view class="tab-nav">
      <view
        class="tab-item {{activeTab === tab.key ? 'active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="key"
        bindtap="switchTab"
        data-key="{{tab.key}}"
      >
        <text class="tab-label">{{ tab.label }}</text>
        <view class="tab-count" wx:if="{{tab.count > 0}}">{{ tab.count }}</view>
      </view>
    </view>

    <!-- 订单列表 -->
    <scroll-view
      scroll-y
      class="order-list-scroll"
      bindscrolltolower="loadMore"
      refresher-enabled
      refresher-triggered="{{isRefreshing}}"
      bindrefresherrefresh="onRefresh"
    >
      <!-- 骨架屏 -->
      <view wx:if="{{loading}}" class="skeleton-container">
        <view class="skeleton skeleton-card" wx:for="{{5}}" wx:key="index"></view>
      </view>

      <!-- 订单列表内容 -->
      <view wx:else class="order-list">
        <view
          class="order-card"
          wx:for="{{filteredOrders}}"
          wx:key="_id"
          bindtap="navigateToOrderDetail"
          data-id="{{item._id}}"
          data-status="{{item.status}}"
          data-service-type="{{item.serviceType}}"
        >
          <!-- 订单头部 -->
          <view class="card-header">
            <view class="service-badge badge-blue">
              <view class="ios-icon css-service-icon {{item.serviceIcon}}"></view>
            </view>
            <view class="card-title-wrap">
              <text class="card-title">{{ item.serviceTypeText }}</text>
              <view class="card-meta">
                <text class="meta-text">{{ item.createdAtText }}</text>
              </view>
            </view>
            <view class="card-price">
              <text class="price-symbol">¥</text>
              <text class="price-value">{{ item.price }}</text>
            </view>
          </view>

          <!-- 订单主体 -->
          <view class="card-body">
            <view class="order-details">
              <view class="location-row" wx:if="{{item.pickupLocation}}">
                <text class="detail-label">取货：</text>
                <text class="location-text">{{ item.pickupLocation }}</text>
              </view>
              <view class="location-row" wx:if="{{item.deliveryLocation}}">
                <text class="detail-label">送达：</text>
                <text class="location-text">{{ item.deliveryLocation }}</text>
              </view>
              <view class="location-row" wx:if="{{item.teachingBuilding}}">
                <text class="detail-label">地点：</text>
                <text class="location-text">{{ item.teachingBuilding }} {{ item.examClassroom || '' }}</text>
              </view>
            </view>
          </view>

          <!-- 订单底部 -->
          <view class="card-footer">
            <text class="order-id">订单编号：{{ item.orderNo || item._id }}</text>
            <view class="order-actions">
              <button
                class="card-btn secondary"
                wx:if="{{item.status === 'PENDING' || item.status === 'WAITING_PAYMENT'}}"
                catchtap="cancelOrder"
                data-id="{{item._id}}"
              >取消</button>
              <button
                class="card-btn primary"
                wx:if="{{item.status === 'WAITING_PAYMENT'}}"
                catchtap="goPay"
                data-id="{{item._id}}"
              >去支付</button>
              <button
                class="card-btn primary"
                wx:if="{{item.status === 'PENDING'}}"
                catchtap="editOrder"
                data-id="{{item._id}}"
              >修改</button>
            </view>
          </view>
        </view>

        <!-- 加载更多 -->
        <view class="load-more" wx:if="{{orders.length > 0 && hasMore && !loading}}">
          <view class="loading-spinner"></view>
          <text class="load-more-text">加载中...</text>
        </view>

        <!-- 没有更多 -->
        <view class="no-more" wx:if="{{orders.length > 0 && !hasMore && !loading}}">
          <text class="no-more-text">没有更多订单了</text>
        </view>

        <!-- 空状态 -->
        <view wx:if="{{!loading && filteredOrders.length === 0}}" class="empty-container">
          <view class="empty-visual">
            <view class="ios-icon icon-order icon-order-empty"></view>
          </view>
          <text class="empty-title">{{ emptyTitle }}</text>
          <text class="empty-desc" wx:if="{{activeTab === 'all'}}">快去发布第一个任务吧</text>
          <button
            class="empty-action"
            wx:if="{{activeTab === 'all'}}"
            bindtap="navigateToPublish"
          >
            <view class="ios-icon icon-school icon-add"></view>
            <text>去发布</text>
          </button>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
