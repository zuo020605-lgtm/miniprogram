/* ============================================
   发布页面样式 - 新设计规范
   ============================================ */

page {
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
}

.publish-page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  overflow-x: hidden;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

/* ========== 动画效果 ========== */
@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ========== 深色模式适配 ========== */
@media (prefers-color-scheme: dark) {
  .publish-page {
    background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
  }
  
  .section-card {
    background-color: #1e293b;
    box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.15);
  }
  
  .section-title {
    color: #f8fafc;
  }
  
  .type-name {
    color: #f8fafc;
  }
  
  .type-desc {
    color: #94a3b8;
  }
  
  .form-input {
    color: #f8fafc;
  }
  
  .picker-value {
    color: #f8fafc;
  }
  
  .form-textarea {
    background-color: #334155;
    color: #f8fafc;
  }
  
  .tips-card {
    background-color: rgba(251, 191, 36, 0.1);
  }
  
  .tips-title,
  .tips-item {
    color: #fcd34d;
  }
}

/* 内容区 */
.publish-content {
  padding: 24rpx;
  padding-bottom: 200rpx;
  overflow-x: hidden;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

/* 卡片样式 */
.section-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.task-type-note {
  background-color: #e5e8ec;
  padding: 16rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.note-text {
  font-size: 20rpx;
  color: #595c5e;
  line-height: 1.5;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 28rpx;
  background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 100%);
  border-radius: 4rpx;
  margin-right: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.4);
}

/* 任务类型网格 - 统一尺寸 */
.task-type-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 24rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
  min-height: 200rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.type-item.active {
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border-color: #3b82f6;
  box-shadow: 0 8rpx 32rpx rgba(59, 130, 246, 0.15);
}

.type-item:active {
  transform: scale(0.985);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.type-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.type-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.type-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.type-item.active .type-name {
  color: #3b82f6;
  font-weight: 700;
}

.type-desc {
  font-size: 22rpx;
  color: #9ca3af;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

/* 表单样式 */
.form-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  overflow: hidden;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

.row-label {
  font-size: 26rpx;
  color: #6b7280;
  width: 160rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.form-input {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #1a1a1a;
  text-align: right;
  max-width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

/* 时间范围 */
.time-range-row {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  flex-wrap: wrap;
}

.time-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  box-sizing: border-box;
}

.time-label {
  font-size: 22rpx;
  color: #9a9da0;
  display: block;
  margin-bottom: 12rpx;
  width: 100%;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.time-separator {
  font-size: 24rpx;
  color: #9a9da0;
  margin: 0 16rpx;
  margin-top: 36rpx;
  flex-shrink: 0;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

/* 选择器样式 */
.picker-value {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  font-size: 26rpx;
  color: #2c2f32;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.picker-arrow {
  font-size: 18rpx;
  color: #9a9da0;
}

/* ========== 重量选择器 - 可拖动 ========== */
.weight-row {
  flex-direction: column;
  align-items: flex-start;
  padding-bottom: 40rpx;
}

.weight-row .row-label {
  margin-bottom: 24rpx;
}

.weight-slider-container {
  width: 100%;
  padding: 20rpx 0;
  box-sizing: border-box;
}

.weight-slider-track {
  position: relative;
  height: 8rpx;
  background-color: #e5e8ec;
  border-radius: 4rpx;
  margin: 40rpx 24rpx 60rpx;
  padding: 0;
  box-sizing: border-box;
}

.weight-slider-progress {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 100%);
  border-radius: 4rpx;
  transition: width 0.1s ease;
}

.weight-slider-thumb {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 100%);
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.4);
  z-index: 10;
  transition: left 0.1s ease;
}

.weight-slider-thumb::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 16rpx;
  background-color: #ffffff;
  border-radius: 50%;
}

.weight-nodes {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  pointer-events: none;
}

.weight-node {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  pointer-events: auto;
}

.node-dot {
  width: 24rpx;
  height: 24rpx;
  background-color: #ffffff;
  border: 4rpx solid #abadb0;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.weight-node.active .node-dot {
  background-color: #3b82f6;
  border-color: #3b82f6;
  transform: scale(1.2);
}

.node-label {
  position: absolute;
  top: 50rpx;
  font-size: 18rpx;
  color: #9ca3af;
  white-space: nowrap;
  transition: color 0.3s ease;
  transform: translateX(-50%);
  z-index: 1;
  text-align: center;
  width: 100rpx;
  left: 50%;
}

.weight-node.active .node-label {
  color: #3b82f6;
  font-weight: 600;
}

.weight-display {
  padding: 16rpx 0;
  text-align: right;
}

.weight-value {
  font-size: 26rpx;
  color: #3b82f6;
  font-weight: 600;
}

/* 价格输入 */
.price-input-wrapper {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: 1;
  overflow: hidden;
  min-width: 0;
}

.price-symbol {
  font-size: 26rpx;
  color: #b31b25;
  font-weight: 600;
  margin-right: 8rpx;
  flex-shrink: 0;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.price-input {
  font-size: 32rpx;
  color: #b31b25;
  font-weight: 700;
  text-align: right;
  width: 160rpx;
  max-width: 160rpx;
  min-width: 0;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

/* 地点选择器 */
.location-input-wrapper {
  width: 100%;
}

.location-input-row {
  display: flex;
  align-items: center;
  background-color: #f8f9fa;
  border-radius: 24rpx;
  overflow: hidden;
}

.location-input-row .form-input {
  background-color: transparent;
  flex: 1;
  border-radius: 24rpx 0 0 24rpx;
}

.location-btn {
  background: linear-gradient(135deg, #1E88E5 0%, #1565C0 100%);
  border: none;
  border-radius: 0 24rpx 24rpx 0;
  padding: 0 24rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.location-btn-full {
  background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 100%);
  border: none;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 26rpx;
  width: 100%;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
  transition: all 0.2s ease;
}

.location-btn-full:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.2);
}

.location-btn-full .location-icon {
  margin-right: 12rpx;
}

.location-icon {
  font-size: 28rpx;
}

/* 文本域 */
.textarea-row {
  flex-direction: column;
  align-items: flex-start;
}

.textarea-row .row-label {
  margin-bottom: 16rpx;
}

.form-textarea {
  width: 100%;
  max-width: 100%;
  min-height: 160rpx;
  font-size: 26rpx;
  color: #2c2f32;
  background-color: #f8f9fa;
  border-radius: 24rpx;
  padding: 20rpx;
  box-sizing: border-box;
  line-height: 1.6;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

/* 表单区域 */
.form-section {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

/* 发布按钮 */
.publish-btn {
  width: 75%;
  max-width: 75%;
  padding: 32rpx;
  background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 100%);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
  transition: all 0.2s ease;
  box-sizing: border-box;
  margin-left: auto;
  margin-right: auto;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.publish-btn:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.2);
}

.publish-btn.disabled {
  background: #c4c7ca;
  box-shadow: none;
}

/* 提示卡片 */
.tips-card {
  background-color: rgba(255, 152, 0, 0.1);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  margin-bottom: 48rpx;
}

.tips-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #ff9800;
  margin-bottom: 12rpx;
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.tips-item {
  font-size: 22rpx;
  color: #ff9800;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.5;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.tips-item:last-child {
  margin-bottom: 0;
}
