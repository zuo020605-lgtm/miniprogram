  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.96), 0 18rpx 44rpx rgba(22, 38, 58, 0.1) !important;
}

.publish-page .task-type-note,
.publish-page .location-input-row,
.publish-page .form-textarea {
  background: rgba(241, 247, 252, 0.96) !important;
  border: 1rpx solid rgba(0, 88, 187, 0.1) !important;
}

.publish-page .type-item:nth-child(1) {
  background: linear-gradient(145deg, rgba(232, 246, 255, 0.96), rgba(219, 239, 255, 0.78)) !important;
}

.publish-page .type-item:nth-child(2) {
  background: linear-gradient(145deg, rgba(229, 255, 248, 0.96), rgba(199, 244, 236, 0.78)) !important;
}

.publish-page .type-item:nth-child(3) {
  background: linear-gradient(145deg, rgba(255, 247, 225, 0.96), rgba(255, 232, 181, 0.78)) !important;
}

.publish-page .type-item:nth-child(4) {
  background: linear-gradient(145deg, rgba(255, 237, 234, 0.96), rgba(255, 216, 208, 0.78)) !important;
}

.publish-page .type-item.active {
  border-color: rgba(0, 88, 187, 0.34) !important;
