.publish-page .type-item.active .type-name,
.publish-page .weight-value,
.publish-page .weight-node.active .node-label {
  color: #4f6675 !important;
}

.publish-page .type-icon-wrapper {
  background: rgba(96, 120, 137, 0.12) !important;
  color: #607889 !important;
}

.publish-page .task-type-note,
.publish-page .location-input-row,
.publish-page .form-textarea {
  background: rgba(238, 243, 244, 0.96) !important;
  border-color: rgba(105, 124, 134, 0.12) !important;
