.publish-page .publish-btn {
  background: linear-gradient(135deg, #0058bb 0%, #0a84ff 100%) !important;
  color: #ffffff !important;
  box-shadow: 0 14rpx 32rpx rgba(0, 88, 187, 0.24) !important;
}

/* Morandi publish pass. */
