    radial-gradient(circle at 88% 8%, rgba(129, 148, 135, 0.1), rgba(129, 148, 135, 0) 30%),
    linear-gradient(180deg, #f3f5f6 0%, #e8edf0 100%) !important;
}

.publish-page .section-card {
  background: rgba(253, 254, 253, 0.96) !important;
  border-color: rgba(105, 124, 134, 0.18) !important;
  box-shadow: 0 16rpx 42rpx rgba(58, 70, 76, 0.1) !important;
}

.publish-page .section-title::before,
.publish-page .weight-slider-progress,
.publish-page .weight-slider-thumb {
  background: #607889 !important;
  box-shadow: none !important;
}

.publish-page .type-item,
.publish-page .type-item:nth-child(1),
.publish-page .type-item:nth-child(2),
.publish-page .type-item:nth-child(3),
