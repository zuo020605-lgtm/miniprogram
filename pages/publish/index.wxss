  border-color: rgba(105, 124, 134, 0.24) !important;
}

.publish-page .location-select-row {
  align-items: center;
}

.publish-page .location-select-content {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.publish-page .location-display {
  flex: 1;
  min-width: 0;
  min-height: 56rpx;
  display: flex;
