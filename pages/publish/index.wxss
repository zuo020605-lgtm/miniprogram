.publish-page .location-display-text {
  flex: 1;
  min-width: 0;
  color: #4f6675;
  font-size: 28rpx;
  line-height: 1.45;
  word-break: break-all;
}

.publish-page .location-display.has-location .location-display-text {
  color: #2d3336;
  font-weight: 500;
}

.publish-page .location-btn-inline {
  flex: 0 0 204rpx;
  width: 204rpx;
  min-width: 204rpx;
  height: 64rpx;
  min-height: 64rpx;
  padding: 0 18rpx !important;
  margin: 0 !important;
  border-radius: 16rpx !important;
  font-size: 24rpx !important;
  line-height: 64rpx !important;
  display: flex !important;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  box-sizing: border-box;
  overflow: visible;
}

.publish-page .location-btn-inline::after {
  border: 0;
}

.publish-page .location-btn-inline text {
  display: block;
  flex: 0 0 auto;
  white-space: nowrap;
  line-height: 1.1 !important;
  font-size: 24rpx !important;
}

.publish-page .location-btn-inline .ios-icon,
.publish-page .location-btn-inline .location-icon {
  flex: 0 0 24rpx;
  width: 24rpx;
  height: 24rpx;
  min-width: 24rpx;
  font-size: 24rpx !important;
  transform: scale(0.82);
}

.publish-page .location-btn text,
.publish-page .location-btn .ios-icon,
.publish-page .location-btn-full text,
.publish-page .location-btn-full .ios-icon,
.publish-page .location-btn-full .location-icon,
.publish-page .location-btn-inline text,
.publish-page .location-btn-inline .ios-icon,
.publish-page .location-btn-inline .location-icon {
  color: #4f6675 !important;
}

.publish-page .publish-btn {
  background: linear-gradient(135deg, #607889 0%, #4f6675 100%) !important;
  box-shadow: 0 12rpx 28rpx rgba(79, 102, 117, 0.2) !important;
}
