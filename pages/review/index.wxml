<view class="review-page">
    <!-- 导航栏-->
    <view class="review-navbar">
      <view class="navbar-left" bindtap="navigateBack">
        <view class="ios-icon icon-back icon-nav"></view>
      </view>
      <text class="navbar-title">评价订单</text>
      <view class="navbar-right"></view>
    </view>

    <!-- 订单信息 -->
    <view class="order-info-card">
      <view class="order-header">
        <view class="order-icon">
          <view class="ios-icon icon-school icon-nav"></view>
        </view>
        <view class="order-text">
          <text class="order-title">{{ order.title || '校园跑腿任务' }}</text>
          <text class="order-price">{{ priceText }}</text>
        </view>
      </view>
    </view>

    <!-- 评分 -->
    <view class="rating-card">
      <text class="card-title">服务评分</text>
      <view class="rating-stars">
        <view 
          class="star-item {{index < rating ? 'active' : ''}}"
          wx:for="{{5}}" 
          wx:key="index"
          data-rating="{{index + 1}}"
          bindtap="handleRating"
        >
          <view class="ios-icon icon-star icon-nav"></view>
        </view>
      </view>
      <text class="rating-text">{{ ratingText }}</text>
    </view>

    <!-- 评价标签 -->
    <view class="tags-card">
      <text class="card-title">选择标签</text>
      <view class="tags-list">
        <view 
          class="tag-item {{selectedTags.includes(tag) ? 'active' : ''}}" 
          wx:for="{{tags}}" wx:for-item="tag" wx:for-index="index" wx:key="{{tag}}"
          bindtap="toggleTag"
          data-tag="{{tag}}"
        >
          <text>{{ tag }}</text>
        </view>
      </view>
    </view>

    <!-- 评价内容 -->
    <view class="content-card">
      <text class="card-title">评价内容</text>
      <textarea 
        value="{{content}}" bindinput="handleContentChange" 
        placeholder="分享您的服务体验，帮助其他用户.."
        class="review-textarea"
        maxlength="500"
      />
      <view class="char-count">{{ content.length }}/500</view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-bar">
      <button class="submit-btn" bindtap="submitReview" disabled="{{!canSubmit}}">
        <text wx:if="{{!submitting}}">提交评价</text>
        <text wx:else>提交中..</text>
      </button>
    </view>
  </view>
