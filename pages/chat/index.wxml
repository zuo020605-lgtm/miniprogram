<view class="chat-page">
    <!-- 顶部导航 -->
    <view class="chat-navbar">
      <view class="navbar-left" bindtap="navigateBack">
        <view class="ios-icon icon-back icon-nav"></view>
      </view>
      <view class="navbar-center">
        <text class="navbar-title">{{ chatUserName }}</text>
        <text class="navbar-status">在线</text>
      </view>
      <view class="navbar-right">
        <view class="ios-icon icon-more icon-nav"></view>
      </view>
    </view>

    <!-- 消息列表 -->
    <scroll-view 
      scroll-y 
      class="message-list" 
      scroll-top="{{scrollTop}}"
      bindscrolltoupper="loadMoreMessages"
    >
      <view
        class="message-item {{msg.isSelf ? 'message-self' : ''}}"
        wx:for="{{messages}}" wx:for-item="msg" wx:for-index="index" wx:key="{{index}}"
      >
        <view class="message-avatar" wx:if="{{!msg.isSelf}}">
          <text class="avatar-text">{{ chatUserName ? chatUserName.charAt(0) : 'U' }}</text>
        </view>

        <view class="message-content">
          <view class="message-bubble">
            <text class="message-text">{{ msg.content }}</text>
          </view>
          <text class="message-time">{{ msg.formattedTime }}</text>
        </view>

        <view class="message-avatar" wx:if="{{msg.isSelf}}">
          <text class="avatar-text">我</text>
        </view>
      </view>
    </scroll-view>

    <!-- 输入框-->
    <view class="input-bar">
      <view class="input-wrapper">
        <input 
          type="text" 
          value="{{inputText}}" bindinput="onInputTextChange" 
          placeholder="输入消息..." 
          class="message-input"
          bindconfirm="sendMessage"
        />
        <view class="input-actions">
          <view class="ios-icon icon-camera icon-nav"></view>
        </view>
      </view>
      <button class="send-btn" bindtap="sendMessage" disabled="{{!inputText.trim()}}">
        <view class="ios-icon icon-send icon-nav"></view>
      </button>
    </view>
  </view>
