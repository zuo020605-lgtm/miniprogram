<view class="order-detail-page">
  <!-- 内容区 -->
  <scroll-view scroll-y class="content-scroll">
    <!-- 状态卡片 -->
    <view class="status-card {{'status-' + order.status}}">
      <view class="status-header">
        <view class="status-icon-wrapper">
          <view class="ios-icon icon-school status-icon"></view>
        </view>
        <view class="status-info">
          <text class="status-title">{{ order.statusText }}</text>
          <text class="status-desc">{{ order.statusDesc }}</text>
        </view>
      </view>

      <!-- 进度条 -->
      <view class="progress-container" wx:if="{{order.status !== 'cancelled'}}">
        <view class="progress-track">
          <view class="progress-fill" style="width: {{order.progressPercent}}%"></view>
        </view>
        <view class="progress-steps">
          <view
            class="progress-step {{index <= order.currentStep ? 'active' : ''}} {{index === order.currentStep ? 'current' : ''}}"
            wx:for="{{steps}}"
            wx:for-item="step"
            wx:key="index"
          >
            <view class="step-dot">
              <text class="step-check" wx:if="{{index < order.currentStep}}">✓</text>
            </view>
            <text class="step-label">{{step}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 基本信息卡片 -->
    <view class="info-card">
      <view class="card-header">
        <text class="card-title">基本信息</text>
      </view>
      <view class="info-grid">
        <view class="info-item">
          <text class="info-label">任务标题</text>
          <text class="info-value">{{order.title || '未设置'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">任务金额</text>
          <text class="info-value price">¥{{order.price}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">发布时间</text>
          <text class="info-value">{{order.createdAtText}}</text>
        </view>
        <view class="info-item" wx:if="{{order.startTime}}">
          <text class="info-label">开始时间</text>
          <text class="info-value">{{order.startTimeText}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">订单编号</text>
          <view class="info-value copyable" bindtap="copyOrderNo">
            <text class="order-no">{{order.orderNo || order._id}}</text>
            <view class="ios-icon icon-copy copy-icon"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 服务详情卡片 -->
    <view class="info-card">
      <view class="card-header">
        <text class="card-title">服务详情</text>
      </view>

      <!-- 校园跑腿/快递代取 -->
      <view wx:if="{{order.serviceType === 'campus-errand' || order.serviceType === 'express'}}">
        <view class="info-item">
          <text class="info-label">取货地点</text>
          <text class="info-value">{{order.pickupLocation || '未设置'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">送达地点</text>
          <text class="info-value">{{order.deliveryLocation || '未设置'}}</text>
        </view>
        <view class="info-item" wx:if="{{order.serviceType === 'express' && order.weight}}">
          <text class="info-label">物品重量</text>
          <text class="info-value">{{order.weight}}</text>
        </view>
      </view>

      <!-- 校园代课/考试代替 -->
      <view wx:if="{{order.serviceType === 'campus-class' || order.serviceType === 'exam'}}">
        <view class="info-item">
          <text class="info-label">{{order.serviceType === 'campus-class' ? '上课地点' : '考试地点'}}</text>
          <text class="info-value">{{order.examLocation || order.teachingBuilding || '未设置'}}</text>
        </view>
        <view class="info-item" wx:if="{{order.examSubject}}">
          <text class="info-label">{{order.serviceType === 'campus-class' ? '课程' : '考试科目'}}</text>
          <text class="info-value">{{order.examSubject || '未设置'}}</text>
        </view>
        <view class="info-item" wx:if="{{order.examClassroom}}">
          <text class="info-label">教室</text>
          <text class="info-value">{{order.examClassroom || '未设置'}}</text>
        </view>
        <view class="info-item" wx:if="{{order.serviceType === 'campus-class'}}">
          <text class="info-label">是否签到</text>
          <text class="info-value">{{order.needSignIn ? '需要' : '不需要'}}</text>
        </view>
        <view class="info-item" wx:if="{{order.serviceType === 'campus-class' && order.classroomSize}}">
          <text class="info-label">教室类型</text>
          <text class="info-value">{{order.classroomSize === 'large' ? '大教室' : '小教室'}}</text>
        </view>
      </view>

      <!-- 任务详情 -->
      <view class="info-item" wx:if="{{order.taskDetail}}">
        <text class="info-label">任务详情</text>
        <text class="info-value detail">{{order.taskDetail}}</text>
      </view>
    </view>

    <!-- 接单人信息 -->
    <view class="info-card" wx:if="{{order.courierNickname}}">
      <view class="card-header">
        <text class="card-title">接单人信息</text>
      </view>
      <view class="courier-info">
        <view class="courier-avatar">
          <text class="avatar-text">{{order.courierNickname.charAt(0)}}</text>
        </view>
        <view class="courier-details">
          <text class="courier-name">{{order.courierNickname}}</text>
          <text class="courier-badge">接单员</text>
        </view>
        <button class="contact-btn" bindtap="contactCourier">
          <view class="ios-icon icon-message contact-icon"></view>
          <text class="contact-text">联系</text>
        </button>
      </view>
    </view>

    <!-- 评价信息 -->
    <view class="info-card review-card" wx:if="{{order.reviewed && order.review}}">
      <view class="card-header">
        <text class="card-title">评价信息</text>
      </view>
      <view class="review-summary">
        <text class="review-rating">{{order.reviewRatingText}}</text>
        <text class="review-time">{{order.reviewTimeText}}</text>
      </view>
      <text class="review-content">{{order.review.content || '暂无文字评价'}}</text>
      <view class="review-tags" wx:if="{{order.reviewTagsText}}">
        <text>{{order.reviewTagsText}}</text>
      </view>
    </view>

    <!-- 底部操作区 -->
    <view class="bottom-actions">
      <button
        class="action-btn secondary"
        wx:if="{{permissions.canCancel}}"
        bindtap="cancelOrder"
      >
        取消订单
      </button>
      <button
        class="action-btn primary"
        wx:if="{{permissions.canAccept}}"
        bindtap="acceptOrder"
      >
        接取任务
      </button>
      <button
        class="action-btn primary"
        wx:if="{{permissions.canPay}}"
        bindtap="goPay"
      >
        去支付
      </button>
      <button
        class="action-btn primary"
        wx:if="{{permissions.canEdit}}"
        bindtap="editOrder"
      >
        修改订单
      </button>
      <button
        class="action-btn primary"
        wx:if="{{permissions.canFinish}}"
        bindtap="confirmComplete"
      >
        确认完成
      </button>
      <button
        class="action-btn primary"
        wx:if="{{permissions.canReview}}"
        bindtap="goReview"
      >
        去评价
      </button>
    </view>
  </scroll-view>
</view>
