  color: #2f3538 !important;
  border: 1rpx solid rgba(105, 124, 134, 0.2) !important;
  box-shadow: 0 16rpx 42rpx rgba(58, 70, 76, 0.12) !important;
}

.order-detail-page .status-card.status-pending,
.order-detail-page .status-card.status-waitingPayment {
