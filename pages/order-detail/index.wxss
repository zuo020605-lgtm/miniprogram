/* ============================================
   订单详情页样式 - Material Design 3
   ============================================ */

page {
  background-color: #f5f7fa;
}

.order-detail-page {
  min-height: 100vh;
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'San Francisco', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  box-sizing: border-box;
}

/* 内容区 */
.content-scroll {
  padding: 24rpx;
  padding-top: 24rpx;
  padding-bottom: 200rpx;
  box-sizing: border-box;
  max-width: 100vw;
  overflow-x: hidden;
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #005da4 0%, #00518f 100%);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 93, 164, 0.3);
  color: #ffffff;
  box-sizing: border-box;
  max-width: 100%;
  overflow: hidden;
}

.status-card.status-pending {
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
}

.status-card.status-processing {
  background: linear-gradient(135deg, #005da4 0%, #00518f 100%);
}

.status-card.status-completed {
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
}

.status-card.status-reviewed {
  background: linear-gradient(135deg, #005da4 0%, #4CAF50 100%);
}

.status-card.status-cancelled {
  background: linear-gradient(135deg, #b31b25 0%, #9f0519 100%);
}

.status-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.status-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.status-icon {
  width: 48rpx;
  height: 48rpx;
}

.status-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 进度条 */
.progress-container {
  margin-top: 24rpx;
}

.progress-track {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #ffffff;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-steps {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
}

.step-dot {
  width: 28rpx;
  height: 28rpx;
  background: rgba(255, 255, 255, 0.28);
  border: 2rpx solid rgba(255, 255, 255, 0.55);
  border-radius: 50%;
  margin-bottom: 8rpx;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-step.active .step-dot {
  background: #ffffff;
  transform: scale(1.2);
}

.progress-step.current .step-dot {
  box-shadow: 0 0 0 8rpx rgba(255, 255, 255, 0.18);
}

.step-check {
  color: #005da4;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 1;
}

.step-label {
  font-size: 20rpx;
  opacity: 0.8;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.progress-step.active .step-label {
  opacity: 1;
  font-weight: 600;
}

/* 信息卡片 */
.info-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
  max-width: 100%;
  overflow: hidden;
}

.card-header {
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f2f5;
  padding-bottom: 16rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c2f32;
}

/* 信息网格 */
.info-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
}

.info-label {
  font-size: 24rpx;
  color: #6c757d;
  flex-shrink: 0;
  width: 140rpx;
}

.info-value {
  flex: 1;
  font-size: 24rpx;
  color: #2c2f32;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-value.price {
  font-size: 32rpx;
  font-weight: 700;
  color: #b31b25;
}

.info-value.detail {
  text-align: left;
  white-space: normal;
  line-height: 1.5;
}

.copyable {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}

.order-no {
  font-size: 20rpx;
  color: #6c757d;
  font-family: monospace;
}

.copy-icon {
  width: 20rpx;
  height: 20rpx;
  opacity: 0.6;
}

/* 接单人信息 */
.courier-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 16rpx 0;
}

.courier-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #005da4 0%, #00518f 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.courier-details {
  flex: 1;
  min-width: 0;
}

.courier-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c2f32;
  margin-bottom: 4rpx;
}

.courier-badge {
  font-size: 20rpx;
  color: #005da4;
  background-color: rgba(0, 93, 164, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  display: inline-block;
}

.contact-btn {
  padding: 16rpx 32rpx;
  background: #f8f9fa;
  border: 2rpx solid #e9ecef;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.contact-icon {
  width: 24rpx;
  height: 24rpx;
}

.contact-text {
  font-size: 24rpx;
  color: #2c2f32;
  font-weight: 500;
}

/* 底部操作区 */
.bottom-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
  margin-bottom: 48rpx;
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  box-sizing: border-box;
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.action-btn.primary {
  background: linear-gradient(135deg, #005da4 0%, #00518f 100%);
  color: #ffffff;
  border: none;
}

.action-btn.secondary {
  background: #f8f9fa;
  color: #2c2f32;
  border: 2rpx solid #e9ecef;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .info-label {
    width: 120rpx;
    font-size: 22rpx;
  }
  
  .info-value {
    font-size: 22rpx;
  }
  
  .status-title {
    font-size: 32rpx;
  }
  
  .status-desc {
    font-size: 22rpx;
  }
}
