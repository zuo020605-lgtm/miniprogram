<view class="report-page">
    <!-- 导航栏-->
    <view class="report-navbar">
      <view class="navbar-left" bindtap="navigateBack">
        <image class="icon-arrow-left" src="/static/close-icon.png" style="width: 24rpx; height: 24rpx;" />
      </view>
      <text class="navbar-title">举报投诉</text>
      <view class="navbar-right"></view>
    </view>

    <!-- 举报类型 -->
    <view class="type-card">
      <text class="card-title">举报类型</text>
      <view class="type-list">
        <view 
          class="type-item {{selectedType === index ? 'active' : ''}}" 
          wx:for="{{reportTypes}}" wx:for-item="type" wx:for-index="index" wx:key="{{type.id || index}}"
          bindtap="selectType"
          data-index="{{index}}"
        >
          <image src="/static/school-icon.png" style="width: 24rpx; height: 24rpx;" />
          <text>{{ type.name }}</text>
        </view>
      </view>
    </view>

    <!-- 详细描述 -->
    <view class="desc-card">
      <text class="card-title">详细描述</text>
      <textarea 
        value="{{description}}" bindinput="onDescriptionChange" 
        placeholder="请详细描述您遇到的问题.."
        class="desc-textarea"
        maxlength="500"
      />
      <view class="char-count">{{ description.length }}/500</view>
    </view>

    <!-- 上传图片 -->
    <view class="image-card">
      <text class="card-title">上传凭证（选填）</text>
      <view class="image-list">
        <view class="image-item" wx:for="{{images}}" wx:for-item="img" wx:for-index="index" wx:key="{{img || index}}">
          <image src="{{img}}" mode="aspectFill" class="preview-image" />
          <view class="remove-btn" bindtap="removeImage" data-index="{{index}}">
            <image class="icon-close" src="/static/close-icon.png" style="width: 16rpx; height: 16rpx;" />
          </view>
        </view>
        <view class="add-image" wx:if="{{images.length < 3}}" bindtap="chooseImage">
          <image class="icon-camera" src="/static/school-icon.png" style="width: 32rpx; height: 32rpx;" />
          <text class="add-text">添加图片</text>
        </view>
      </view>
    </view>

    <!-- 联系方式 -->
    <view class="contact-card">
      <text class="card-title">联系方式（选填）</text>
      <input 
        value="{{contact}}" bindinput="onContactChange" 
        placeholder="请输入手机号或微信号"
        class="contact-input"
        type="text"
      />
    </view>

    <!-- 提示 -->
    <view class="tip-card">
      <image class="icon-shield" src="/static/school-icon.png" style="width: 18rpx; height: 18rpx;" />
      <text class="tip-text">我们将对您的举报信息严格保密，并在1-3个工作日内处理</text>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-bar">
      <button class="submit-btn" bindtap="submitReport" disabled="{{!canSubmit}}">
        <text wx:if="{{!submitting}}">提交举报</text>
        <text wx:else>提交中..</text>
      </button>
    </view>
  </view>
