<view class="popular-tasks-page">
    <view class="tasks-list">
      <!-- 订单列表 -->
      <view class="task-card" wx:for="{{unacceptedOrders}}" wx:key="index" bindtap="navigateToOrderDetail" data-id="{{item._id}}">
        <view class="task-header">
          <view class="task-tag">
            <text>{{ item.tagText || '待接单' }}</text>
          </view>
          <text class="task-price">¥{{ item.price }}</text>
        </view>
        <text class="task-title">{{ item.title }}</text>
        <view class="task-info">
          <view class="task-info-item">
            <image class="icon-location" src="/static/school-icon.png" style="width: 20rpx; height: 20rpx;" />
            <text class="task-info-text" wx:if="{{item.pickupLocation && item.deliveryLocation}}">{{ item.pickupLocation }} -> {{ item.deliveryLocation }}</text>
            <text class="task-info-text" wx:elif="{{item.teachingBuilding && item.examClassroom}}">{{ item.teachingBuilding }} {{ item.examClassroom }}</text>
            <text class="task-info-text" wx:else>{{ item.location || '未知位置' }}</text>
          </view>
          <view class="task-info-item">
            <image class="icon-time" src="/static/school-icon.png" style="width: 20rpx; height: 20rpx;" />
            <text class="task-info-text">{{ item.startTimeText || '尽快' }}</text>
          </view>
        </view>
        <view class="task-footer">
          <text class="task-time">{{ item.createdAtText || '刚刚' }}</text>
        </view>
      </view>
      
      <!-- 加载状态 -->
      <view class="loading" wx:if="{{loading}}">
        <text class="loading-text">加载中...</text>
      </view>
      
      <!-- 空状态 -->
      <view class="no-tasks" wx:if="{{!loading && unacceptedOrders.length === 0}}">
        <text class="no-tasks-text">暂无未接取的任务</text>
      </view>
    </view>
  </view>
