.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 8rpx;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* 任务卡片骨架屏 */
.skeleton-task-card {
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.skeleton-task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.skeleton-tag {
  width: 80rpx;
  height: 40rpx;
  border-radius: 20rpx;
}

.skeleton-price {
  width: 100rpx;
  height: 36rpx;
}

.skeleton-title {
  width: 100%;
  height: 32rpx;
  margin-bottom: 16rpx;
}

/* 订单列表骨架屏 */
.skeleton-order-item {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.skeleton-order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f2f5;
}

.skeleton-status {
  width: 100rpx;
  height: 32rpx;
  border-radius: 8rpx;
}

.skeleton-time {
  width: 160rpx;
  height: 24rpx;
}

.skeleton-order-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.skeleton-type {
  width: 200rpx;
  height: 32rpx;
}

.skeleton-amount {
  width: 120rpx;
  height: 32rpx;
}

.skeleton-order-footer {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f2f5;
}

.skeleton-id {
  width: 300rpx;
  height: 24rpx;
}

/* 消息列表骨架屏 */
.skeleton-message-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.skeleton-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.skeleton-message-content {
  flex: 1;
}

.skeleton-name {
  width: 120rpx;
  height: 32rpx;
  margin-bottom: 16rpx;
}

.skeleton-preview {
  width: 300rpx;
  height: 24rpx;
}

/* 用户信息骨架屏 */
.skeleton-user-profile {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.skeleton-avatar-large {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.skeleton-user-info {
  flex: 1;
}

.skeleton-username {
  width: 160rpx;
  height: 40rpx;
  margin-bottom: 16rpx;
}

.skeleton-userid {
  width: 200rpx;
  height: 28rpx;
}

/* 统计数据骨架屏 */
.skeleton-stats {
  display: flex;
  justify-content: space-between;
  padding: 32rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
}

.skeleton-stat-item {
  flex: 1;
  text-align: center;
}

.skeleton-stat-value {
  width: 80rpx;
  height: 48rpx;
  margin: 0 auto 16rpx;
}

.skeleton-stat-label {
  width: 100rpx;
  height: 24rpx;
  margin: 0 auto;
}

/* 功能网格骨架屏 */
.skeleton-function-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32rpx;
  padding: 32rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
}

.skeleton-function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.skeleton-function-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
}

.skeleton-function-text {
  width: 80rpx;
  height: 24rpx;
}

/* 通用列表骨架屏 */
.skeleton-list {
  padding: 24rpx;
}

.skeleton-list-item {
  padding: 32rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.skeleton-line {
  width: 100%;
  height: 28rpx;
  margin-bottom: 16rpx;
}

/* 卡片骨架屏 */
.skeleton-card-wrapper {
  padding: 24rpx;
}

.skeleton-card {
  width: 100%;
  background-color: #ffffff;
  border-radius: 24rpx;
}