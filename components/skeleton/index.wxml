<view class="skeleton-wrapper">
    <!-- 任务卡片骨架屏 -->
    <view wx:if="{{type === 'task-card'}}" class="skeleton-task-card">
      <view class="skeleton skeleton-task-header">
        <view class="skeleton skeleton-tag"></view>
        <view class="skeleton skeleton-price"></view>
      </view>
      <view class="skeleton skeleton-title"></view>
      <view class="skeleton skeleton-text"></view>
      <view class="skeleton skeleton-text" style="width: 60%;"></view>
    </view>
    
    <!-- 订单列表骨架屏 -->
    <view wx:elif="{{type === 'order-item'}}" class="skeleton-order-item">
      <view class="skeleton-order-header">
        <view class="skeleton skeleton-status"></view>
        <view class="skeleton skeleton-time"></view>
      </view>
      <view class="skeleton-order-body">
        <view class="skeleton skeleton-type"></view>
        <view class="skeleton skeleton-amount"></view>
      </view>
      <view class="skeleton-order-footer">
        <view class="skeleton skeleton-id"></view>
      </view>
    </view>
    
    <!-- 消息列表骨架屏 -->
    <view wx:elif="{{type === 'message-item'}}" class="skeleton-message-item">
      <view class="skeleton skeleton-avatar"></view>
      <view class="skeleton-message-content">
        <view class="skeleton skeleton-name"></view>
        <view class="skeleton skeleton-preview"></view>
      </view>
    </view>
    
    <!-- 用户信息骨架屏 -->
    <view wx:elif="{{type === 'user-profile'}}" class="skeleton-user-profile">
      <view class="skeleton skeleton-avatar-large"></view>
      <view class="skeleton-user-info">
        <view class="skeleton skeleton-username"></view>
        <view class="skeleton skeleton-userid"></view>
      </view>
    </view>
    
    <!-- 统计数据骨架屏 -->
    <view wx:elif="{{type === 'stats'}}" class="skeleton-stats">
      <view class="skeleton-stat-item" wx:for="{{count}}" wx>
        <view class="skeleton skeleton-stat-value"></view>
        <view class="skeleton skeleton-stat-label"></view>
      </view>
    </view>
    
    <!-- 功能网格骨架屏 -->
    <view wx:elif="{{type === 'function-grid'}}" class="skeleton-function-grid">
      <view class="skeleton-function-item" wx:for="{{count}}" wx>
        <view class="skeleton skeleton-function-icon"></view>
        <view class="skeleton skeleton-function-text"></view>
      </view>
    </view>
    
    <!-- 通用列表骨架屏 -->
    <view wx:elif="{{type === 'list'}}" class="skeleton-list">
      <view class="skeleton-list-item" wx:for="{{count}}" wx>
        <view class="skeleton skeleton-line"></view>
        <view class="skeleton skeleton-line" style="width: 70%;"></view>
      </view>
    </view>
    
    <!-- 卡片骨架屏 -->
    <view wx:elif="{{type === 'card'}}" class="skeleton-card-wrapper">
      <view class="skeleton skeleton-card"></view>
    </view>
  </view>
